# =============================================================================
# ContractToCozy — Local Development Secrets
# =============================================================================
# Copy this file to .env.local and fill in every value.
# .env.local is gitignored and must NEVER be committed.
#
# Start the stack with:
#   docker compose --env-file .env.local up
#
# Generate strong random values with:
#   openssl rand -hex 32
# =============================================================================

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_PASSWORD=changeme-use-openssl-rand-hex-32

# --- Redis --------------------------------------------------------------------
REDIS_PASSWORD=changeme-use-openssl-rand-hex-32

# --- JWT signing keys (one per token type) ------------------------------------
JWT_SECRET=changeme-use-openssl-rand-hex-32
JWT_REFRESH_SECRET=changeme-use-openssl-rand-hex-32
JWT_MFA_SECRET=changeme-use-openssl-rand-hex-32

# --- Session & CSRF -----------------------------------------------------------
SESSION_SECRET=changeme-use-openssl-rand-hex-32
CSRF_SECRET=changeme-use-openssl-rand-hex-32

# --- MFA TOTP encryption (32-byte AES-256 key as 64 hex chars) ---------------
MFA_ENCRYPTION_KEY=changeme-use-openssl-rand-hex-32

# --- CORS (comma-separated list of allowed frontend origins) ------------------
# In development this defaults to http://localhost:3000 if left empty.
ALLOWED_ORIGINS=http://localhost:3000

# --- Optional services --------------------------------------------------------
GEMINI_API_KEY=
METRICS_BEARER_TOKEN=
SWAGGER_PASSWORD=
