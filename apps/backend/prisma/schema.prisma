  slug     String  @unique
  name     String
  tagGroup String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Relations
  articles KnowledgeArticleTag[]

  @@index([tagGroup])
  @@index([isActive])
  @@map("knowledge_tags")
