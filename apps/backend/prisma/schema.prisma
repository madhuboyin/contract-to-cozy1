// New history table (weekly buckets)
model PropertyScoreSnapshot {
  id                 String            @id @default(uuid())
  propertyId         String
  homeownerProfileId String
  scoreType          PropertyScoreType

  // Current score value for that week
  score    Float
  scoreMax Float? // optional (ex: health can be 71 max)

  // Optional UX helpers (can also be derived at read time)
  scoreBand        String? // "Excellent", "Fair", etc.
  sourceVersion    Int     @default(1)
  confidenceScore  Int?
  calculationRunId String?
  reportEligible   Boolean @default(false)

  // Monday 00:00:00 (or your chosen canonical week bucket in UTC)
  weekStart DateTime

  computedAt   DateTime @default(now())
  snapshotJson Json? // factors/drivers/metadata for "what changed"
  createdAt    DateTime @default(now())

  property         Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  homeownerProfile HomeownerProfile @relation(fields: [homeownerProfileId], references: [id], onDelete: Cascade)

  @@unique([propertyId, scoreType, weekStart])
  @@index([propertyId, scoreType, weekStart(sort: Desc)])
  @@index([homeownerProfileId, scoreType, weekStart(sort: Desc)])
  @@index([computedAt(sort: Desc)])
  @@index([propertyId, reportEligible, weekStart(sort: Desc)])
  @@map("property_score_snapshots")
}

model HomeScoreReport {
  id                  String                @id @default(uuid())
  propertyId          String
  preferenceProfileId String?
  generatedByUserId String?
  reportMode        HomeScoreReportMode   @default(HOMEOWNER)
  reportVersion     String                @default("2.0")
  scoreModelVersion String?
  status            HomeScoreReportStatus @default(FINAL)
  generatedAt       DateTime              @default(now())
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  property           Property                      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  preferenceProfile  PreferenceProfile?            @relation(fields: [preferenceProfileId], references: [id], onDelete: SetNull)
  sections           HomeScoreReportSection[]
  certifications     HomeScoreCertification[]
  evidenceLinks      HomeScoreReportEvidenceLink[]
  integrityCheckRuns HomeScoreIntegrityCheckRun[]
  financialForecasts HomeScoreFinancialForecast[]
  shareTokens        HomeScoreShareToken[]
  exportJobs         HomeScoreExportJob[]

  @@index([propertyId, generatedAt(sort: Desc)])
  @@index([preferenceProfileId])
  @@index([status, generatedAt(sort: Desc)])
  @@index([reportMode, generatedAt(sort: Desc)])
  @@map("home_score_reports")
}

model HomeScoreReportSection {
  id          String                    @id @default(uuid())
  reportId    String
  sectionKey  HomeScoreReportSectionKey
  sectionJson Json
  hashSha256  String?                   @db.VarChar(64)
  createdAt   DateTime                  @default(now())

  report HomeScoreReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, sectionKey])
  @@index([sectionKey, createdAt(sort: Desc)])
