  insurancePolicy            InsurancePolicy?            @relation(fields: [policyId], references: [id], onDelete: Cascade)
  inventoryItemId            String? // NEW: Link to an InventoryItem record
  inventoryItem              InventoryItem?              @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  homeReportExports          HomeReportExport[]
  claimDocuments             ClaimDocument[]
  homeEventLinks             HomeEventDocument[]
  riskMitigationPlanItems    RiskMitigationPlanItem[]
  capitalTimelineItems       HomeCapitalTimelineItem[]
  negotiationShieldDocuments NegotiationShieldDocument[]
  knowledgeArticleCoverFor   KnowledgeArticle[]          @relation("KnowledgeArticleCoverDocument")

  homeSavingsAccountId     String?
  homeSavingsOpportunityId String?

  homeSavingsAccount     HomeSavingsAccount?     @relation("HomeSavingsAccountDocuments", fields: [homeSavingsAccountId], references: [id], onDelete: SetNull)
  homeSavingsOpportunity HomeSavingsOpportunity? @relation("HomeSavingsOpportunityDocuments", fields: [homeSavingsOpportunityId], references: [id], onDelete: SetNull)

