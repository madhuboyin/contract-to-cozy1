  ctaLinks     KnowledgeArticleCta[]
  events       KnowledgeArticleEvent[]

  @@index([toolType, status])
  @@index([category])
  @@index([status, sortOrder])
  @@map("product_tools")
}

// Controls which tools appear on which article, where, and with what override copy
model KnowledgeArticleToolLink {
  id              String  @id @default(uuid())
  articleId       String
  productToolId   String
  anchorSectionId String?

  placement KnowledgeToolPlacement @default(END_OF_ARTICLE)
  priority  Int                    @default(1)

  customTitle String?
  customBody  String?
  ctaLabel    String?
  isPrimary   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  article       KnowledgeArticle         @relation(fields: [articleId], references: [id], onDelete: Cascade)
  productTool   ProductTool              @relation(fields: [productToolId], references: [id], onDelete: Cascade)
  anchorSection KnowledgeArticleSection? @relation(fields: [anchorSectionId], references: [id], onDelete: SetNull)

  @@index([articleId, placement, priority])
  @@index([productToolId])
  @@index([anchorSectionId])
  @@map("knowledge_article_tool_links")
}

// Rich CTA modules inside articles: tool launch, data prompt, signup, report, internal jump, etc.
model KnowledgeArticleCta {
  id            String  @id @default(uuid())
  articleId     String
  productToolId String?
  sectionId     String?

  ctaType     KnowledgeCtaType
  title       String
  description String?
  ctaLabel    String
  href        String?

  priority Int @default(1)

  // Optional product/data-collection hook
  dataPromptKey  String?
  visibilityRule Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  article     KnowledgeArticle         @relation(fields: [articleId], references: [id], onDelete: Cascade)
  productTool ProductTool?             @relation(fields: [productToolId], references: [id], onDelete: SetNull)
  section     KnowledgeArticleSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  @@index([articleId, priority])
  @@index([productToolId])
  @@index([sectionId])
  @@map("knowledge_article_ctas")
}

// Optional personalization / targeting rules for article variants and CTA visibility
model KnowledgeAudienceRule {
  id        String @id @default(uuid())
  articleId String

  name        String
  description String?
  ruleJson    Json
  priority    Int     @default(1)
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  article KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, isActive, priority])
  @@map("knowledge_audience_rules")
}

// Related / recommended article graph
model KnowledgeArticleRelation {
  sourceArticleId String
  targetArticleId String
  relationType    String
  sortOrder       Int    @default(0)

  createdAt DateTime @default(now())

  // Relations
  sourceArticle KnowledgeArticle @relation("KnowledgeArticleRelationSource", fields: [sourceArticleId], references: [id], onDelete: Cascade)
  targetArticle KnowledgeArticle @relation("KnowledgeArticleRelationTarget", fields: [targetArticleId], references: [id], onDelete: Cascade)

  @@id([sourceArticleId, targetArticleId, relationType])
  @@index([targetArticleId])
  @@map("knowledge_article_relations")
}

// Analytics layer: article view -> tool click -> CTA click -> personalized engagement
model KnowledgeArticleEvent {
  id            String  @id @default(uuid())
  articleId     String
  userId        String?
  propertyId    String?
  productToolId String?
  sectionId     String?

  eventType KnowledgeEventType
  sessionId String?
  metadata  Json?

  createdAt DateTime @default(now())

  // Relations
  article     KnowledgeArticle         @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user        User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)
  property    Property?                @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  productTool ProductTool?             @relation(fields: [productToolId], references: [id], onDelete: SetNull)
  section     KnowledgeArticleSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  @@index([articleId, eventType, createdAt])
  @@index([userId, createdAt])
  @@index([propertyId, createdAt])
  @@index([productToolId, createdAt])
  @@index([sectionId, createdAt])
  @@map("knowledge_article_events")
}

// ============================================================================
// PDF REPORTS
// ============================================================================

enum HomeReportExportType {
  HOME_SUMMARY
  INVENTORY
  MAINTENANCE_HISTORY
  COVERAGE_SNAPSHOT
  HOME_REPORT_PACK
}

enum HomeReportExportStatus {
  PENDING
  GENERATING
  READY
  FAILED
  EXPIRED
  DELETED
}

enum HomeReportExportEventType {
  CREATED
  GENERATION_STARTED
  GENERATED
  DOWNLOADED
  SHARED
  SHARE_REVOKED
  FAILED
  EXPIRED
  DELETED
}

model HomeReportExport {
  id         String @id @default(uuid())
  userId     String
  propertyId String

  type   HomeReportExportType
  status HomeReportExportStatus @default(PENDING)

  // Section toggles / configuration for report-pack
  sections Json?

  // Reproducibility (prevents “why did this change later?”)
  templateVersion Int   @default(1)
  dataVersion     Int   @default(1)
  snapshot        Json? // store the final computed DTO used to render

  // Optional: store generated PDF as a Document row (recommended)
  documentId String?
  document   Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  // Shareable link support (no second table needed)
  shareToken     String?   @unique
  shareExpiresAt DateTime?
  shareRevokedAt DateTime?

  storageBucket String?
  storageKey    String?   @unique
  expiresAt     DateTime?

  // Lifecycle
  requestedAt  DateTime  @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  errorMessage String?

  // Useful metadata
  locale   String?
  timezone String?

  deletedAt         DateTime?
  deletedByUserId   String?
  regeneratedFromId String?

  // Relations
  user     User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property                @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  events   HomeReportExportEvent[]

  @@index([userId, requestedAt])
  @@index([propertyId, requestedAt])
  @@index([status, requestedAt])
  @@index([shareToken])
  @@map("home_report_exports")
}

model HomeReportExportEvent {
  id        String                    @id @default(uuid())
  reportId  String
  type      HomeReportExportEventType
  createdAt DateTime                  @default(now())
  meta      Json?

  report HomeReportExport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, createdAt])
  @@map("home_report_export_events")
}

// ============================================================================
// CLAIMS
// ============================================================================

enum ClaimStatus {
  DRAFT
  IN_PROGRESS
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  DENIED
  CLOSED
}

enum ClaimType {
  WATER_DAMAGE
  FIRE_SMOKE
  STORM_WIND_HAIL
  THEFT_VANDALISM
  LIABILITY
  HVAC
  PLUMBING
  ELECTRICAL
  APPLIANCE
  OTHER
}

enum ClaimSourceType {
  INSURANCE
  HOME_WARRANTY
  MANUFACTURER_WARRANTY
  OUT_OF_POCKET
  UNKNOWN
}

enum ClaimChecklistStatus {
  OPEN
  DONE
  NOT_APPLICABLE
}

enum ClaimDocumentType {
  PHOTO
  VIDEO
  INVOICE
  ESTIMATE
  REPORT
  POLICY
  COMMUNICATION
  RECEIPT
  OTHER
}

enum ClaimTimelineEventType {
  CREATED
  CHECKLIST_GENERATED
  DOCUMENT_ADDED
  SUBMITTED
  INSPECTION_SCHEDULED
  INSPECTION_COMPLETED
  ESTIMATE_RECEIVED
  FOLLOW_UP
  APPROVED
  DENIED
  SETTLEMENT_ISSUED
  CLOSED
  NOTE
  STATUS_CHANGE
  OTHER
}

enum DomainEventType {
  CLAIM_SUBMITTED
  CLAIM_CLOSED
  FOLLOW_UP_DUE
}

enum DomainEventStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

model Claim {
  id         String @id @default(uuid())
  propertyId String
  createdBy  String // userId

  title       String
  description String?
  type        ClaimType
  status      ClaimStatus @default(DRAFT)

  sourceType   ClaimSourceType @default(UNKNOWN)
  providerName String?
  claimNumber  String?
  externalUrl  String?

  // Coverage references (optional)
  insurancePolicyId String?
  warrantyId        String?

  incidentAt  DateTime?
  openedAt    DateTime?
  submittedAt DateTime?
  closedAt    DateTime?

  deductibleAmount    Decimal? @db.Decimal(12, 2)
  estimatedLossAmount Decimal? @db.Decimal(12, 2)
  settlementAmount    Decimal? @db.Decimal(12, 2)

  checklistCompletionPct Int?      @default(0)
  lastActivityAt         DateTime  @default(now())
  nextFollowUpAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  creator  User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  insurancePolicy InsurancePolicy? @relation(fields: [insurancePolicyId], references: [id], onDelete: SetNull)
  warranty        Warranty?        @relation(fields: [warrantyId], references: [id], onDelete: SetNull)

  checklistItems ClaimChecklistItem[]
  documents      ClaimDocument[]
  timelineEvents ClaimTimelineEvent[]
  homeEvents     HomeEvent[]

  @@index([propertyId, status])
  @@index([createdBy, status])
  @@index([propertyId, lastActivityAt])
  @@index([nextFollowUpAt])
  @@map("claims")
}

model ClaimChecklistItem {
  id      String @id @default(uuid())
  claimId String

  orderIndex  Int
  title       String
  description String?
  required    Boolean @default(false)

  status      ClaimChecklistStatus @default(OPEN)
  completedAt DateTime?
  completedBy String?

  primaryClaimDocumentId String?

  requiredDocTypes    ClaimDocumentType[] @default([])
  requiredDocMinCount Int                 @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  primaryClaimDocument ClaimDocument? @relation("ClaimChecklistPrimaryDoc", fields: [primaryClaimDocumentId], references: [id], onDelete: SetNull)

  itemDocuments ClaimChecklistItemDocument[]

  @@unique([claimId, orderIndex])
  @@index([claimId, status])
  @@map("claim_checklist_items")
}

model ClaimChecklistItemDocument {
  id                   String   @id @default(uuid())
  claimChecklistItemId String
  claimDocumentId      String
  createdAt            DateTime @default(now())

  item          ClaimChecklistItem @relation(fields: [claimChecklistItemId], references: [id], onDelete: Cascade)
  claimDocument ClaimDocument      @relation(fields: [claimDocumentId], references: [id], onDelete: Cascade)

  @@unique([claimChecklistItemId, claimDocumentId])
  @@index([claimChecklistItemId])
  @@index([claimDocumentId])
  @@map("claim_checklist_item_documents")
}

model ClaimDocument {
  id         String @id @default(uuid())
  claimId    String
  documentId String

  type  ClaimDocumentType @default(OTHER)
  title String?
  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  claim    Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  checklistPrimaryFor ClaimChecklistItem[]         @relation("ClaimChecklistPrimaryDoc")
  timelineEvents      ClaimTimelineEvent[]
  itemDocuments       ClaimChecklistItemDocument[]

  @@unique([claimId, documentId])
  @@index([claimId, type])
  @@index([documentId])
  @@map("claim_documents")
}

model ClaimTimelineEvent {
  id         String @id @default(uuid())
  claimId    String
  propertyId String
  createdBy  String // userId

  type        ClaimTimelineEventType
  title       String?
  description String?

  occurredAt DateTime @default(now())
  meta       Json?

  // Optional attachment
  claimDocumentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  claim    Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  creator  User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  claimDocument ClaimDocument? @relation(fields: [claimDocumentId], references: [id], onDelete: SetNull)

  @@index([claimId, occurredAt])
  @@index([propertyId, occurredAt])
  @@map("claim_timeline_events")
}

model DomainEvent {
  id     String            @id @default(uuid())
  type   DomainEventType
  status DomainEventStatus @default(PENDING)

  // Scope / routing
  propertyId String?
  userId     String?

  // Optional idempotency key to prevent duplicates
  idempotencyKey String? @unique

  // Payload for consumers (workers/notifications)
  payload Json

  attempts  Int     @default(0)
  lastError String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  processedAt DateTime?

  @@index([status, createdAt])
  @@index([type, status])
  @@map("domain_events")
}

// ============================================================================
// RISK TO PREMIUM Optimizer
// ============================================================================

enum RiskPremiumOptimizationStatus {
  READY
  STALE
  ERROR
}

enum NegotiationShieldScenarioType {
  CONTRACTOR_QUOTE_REVIEW
  INSURANCE_PREMIUM_INCREASE
  INSURANCE_CLAIM_SETTLEMENT
  BUYER_INSPECTION_NEGOTIATION
  CONTRACTOR_URGENCY_PRESSURE
}

enum NegotiationShieldCaseStatus {
  DRAFT
  READY_FOR_REVIEW
  ANALYZED
  ARCHIVED
}

enum NegotiationShieldSourceType {
  MANUAL
  DOCUMENT_UPLOAD
  HYBRID
}

enum NegotiationShieldInputType {
  CONTRACTOR_QUOTE
  INSURANCE_PREMIUM
  INSURANCE_CLAIM_SETTLEMENT
  BUYER_INSPECTION
  CONTRACTOR_URGENCY
}

enum NegotiationShieldDocumentType {
  QUOTE
  PREMIUM_NOTICE
  CLAIM_SETTLEMENT_NOTICE
  CLAIM_ESTIMATE
  INSPECTION_REPORT
  BUYER_REQUEST
  CONTRACTOR_RECOMMENDATION
  CONTRACTOR_ESTIMATE
  SUPPORTING_DOCUMENT
}

enum NegotiationShieldDraftType {
  EMAIL
  MESSAGE
}

enum RiskPremiumOptimizationConfidence {
  HIGH
  MEDIUM
  LOW
}

enum MitigationPlanStatus {
  RECOMMENDED
  PLANNED
  DONE
  SKIPPED
}

enum MitigationPriority {
  LOW
  MEDIUM
  HIGH
}

enum MitigationPeril {
  WATER
  FIRE
  WIND_HAIL
  THEFT
  LIABILITY
  ELECTRICAL
  OTHER
}

enum MitigationActionType {
  // Water / plumbing
  LEAK_SENSORS
  AUTO_SHUTOFF_VALVE
  SUMP_PUMP_OR_BACKUP
  WATER_HEATER_REPLACEMENT

  // Roof / wind / exterior
  ROOF_INSPECTION_OR_REPAIR
  TREE_TRIMMING
  WIND_HAIL_HARDENING

  // Fire / safety
  SMOKE_CO_DETECTORS
  ELECTRICAL_PANEL_INSPECTION

  // Security
  SECURITY_SYSTEM

  // Policy levers (non-carrier specific)
  RAISE_DEDUCTIBLE
  REVIEW_DISCOUNTS
}

model RiskPremiumOptimizationAnalysis {
  id                 String @id @default(uuid())
  homeownerProfileId String
  propertyId         String
  assumptionSetId    String?

  status     RiskPremiumOptimizationStatus     @default(READY)
  confidence RiskPremiumOptimizationConfidence

  summary String?

  // Snapshot of inputs and assumptions used for this run
  inputsSnapshot  Json?
  // Ranked premium drivers with explainability
  premiumDrivers  Json?
  // Ranked recommendations and rationale
  recommendations Json?

  // Optional savings estimate range (Decimal to match InsurancePolicy.premiumAmount)
  estimatedSavingsMin Decimal? @db.Decimal(12, 2)
  estimatedSavingsMax Decimal? @db.Decimal(12, 2)

  computedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  homeownerProfile HomeownerProfile @relation(fields: [homeownerProfileId], references: [id], onDelete: Cascade)
  property         Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  assumptionSet    AssumptionSet?   @relation(fields: [assumptionSetId], references: [id], onDelete: SetNull)

  planItems RiskMitigationPlanItem[]

  @@index([homeownerProfileId])
  @@index([assumptionSetId])
  @@index([propertyId, computedAt(sort: Desc)])
  @@index([propertyId, status])
  @@map("risk_premium_optimization_analyses")
}

// ============================================================================
// Negotiation Shield
// ============================================================================

model NegotiationShieldCase {
  id              String  @id @default(uuid())
  propertyId      String
  createdByUserId String?

  scenarioType NegotiationShieldScenarioType
  status       NegotiationShieldCaseStatus   @default(DRAFT)
  sourceType   NegotiationShieldSourceType

  title       String
  description String?

  analysisVersion  String?
  latestAnalysisAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property  Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("NegotiationShieldCaseCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  inputs    NegotiationShieldInput[]
  documents NegotiationShieldDocument[]
  analyses  NegotiationShieldAnalysis[]
  drafts    NegotiationShieldDraft[]
  priceFinalizations PriceFinalization[]

  @@index([propertyId, createdAt(sort: Desc)])
  @@index([propertyId, status])
  @@index([propertyId, scenarioType])
  @@index([createdByUserId])
  @@map("negotiation_shield_cases")
}

model NegotiationShieldInput {
  id     String @id @default(uuid())
  caseId String

  inputType      NegotiationShieldInputType
  rawText        String?
  structuredData Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  negotiationShieldCase NegotiationShieldCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId, createdAt(sort: Desc)])
  @@map("negotiation_shield_inputs")
}

model NegotiationShieldDocument {
  id         String @id @default(uuid())
  caseId     String
  documentId String

  documentType NegotiationShieldDocumentType
  uploadedAt   DateTime                      @default(now())

  negotiationShieldCase NegotiationShieldCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  document              Document              @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([caseId, documentId])
  @@index([caseId, uploadedAt(sort: Desc)])
  @@index([documentId])
  @@map("negotiation_shield_documents")
}

model NegotiationShieldAnalysis {
  id     String @id @default(uuid())
  caseId String

  scenarioType        NegotiationShieldScenarioType
  summary             String?
  findings            Json
  negotiationLeverage Json
  recommendedActions  Json
  pricingAssessment   Json?
  confidence          Float?
  generatedAt         DateTime                      @default(now())
  modelVersion        String?
  createdAt           DateTime                      @default(now())

  negotiationShieldCase NegotiationShieldCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId, generatedAt(sort: Desc)])
  @@index([caseId, scenarioType])
  @@map("negotiation_shield_analyses")
}

model NegotiationShieldDraft {
  id     String @id @default(uuid())
  caseId String

  draftType NegotiationShieldDraftType
  subject   String?
  body      String
  tone      String?
  isLatest  Boolean                    @default(true)
  createdAt DateTime                   @default(now())

  negotiationShieldCase NegotiationShieldCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId, createdAt(sort: Desc)])
  @@index([caseId, isLatest])
  @@map("negotiation_shield_drafts")
}

model RiskMitigationPlanItem {
  id         String @id @default(uuid())
  analysisId String
  propertyId String

  actionType  MitigationActionType
  status      MitigationPlanStatus @default(RECOMMENDED)
  priority    MitigationPriority   @default(MEDIUM)
  targetPeril MitigationPeril?

  title String?
  why   String

  // Optional estimates (Decimal keeps consistency with HomeEvent.amount and InsurancePolicy.premiumAmount)
  estimatedCost       Decimal? @db.Decimal(12, 2)
  estimatedSavingsMin Decimal? @db.Decimal(12, 2)
  estimatedSavingsMax Decimal? @db.Decimal(12, 2)

  // Optional proof links (you already have Document + HomeEvent)
  evidenceDocumentId String?
  linkedHomeEventId  String?

  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  analysis RiskPremiumOptimizationAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  property Property                        @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  evidenceDocument Document?  @relation(fields: [evidenceDocumentId], references: [id], onDelete: SetNull)
  linkedHomeEvent  HomeEvent? @relation(fields: [linkedHomeEventId], references: [id], onDelete: SetNull)

  @@index([analysisId])
  @@index([propertyId, status])
  @@index([propertyId, priority])
  @@index([propertyId, actionType])
  @@map("risk_mitigation_plan_items")
}

// ============================================================================
// Home Capital Timeline
// ============================================================================

enum HomeCapitalTimelineStatus {
  READY
  STALE
  ERROR
}

enum HomeCapitalTimelineConfidence {
  HIGH
  MEDIUM
  LOW
}

enum HomeCapitalTimelinePriority {
  LOW
  MEDIUM
  HIGH
}

enum HomeCapitalTimelineCategory {
  ROOF
  HVAC
  WATER_HEATER
  APPLIANCE
  PLUMBING
  ELECTRICAL
  EXTERIOR
  FOUNDATION
  OTHER
}

enum HomeCapitalTimelineEventType {
  REPLACE
  MAJOR_REPAIR
  INSPECTION
}

enum HomeCapitalTimelineOverrideType {
  PLANNED_DATE // exact planned date
  PLANNED_WINDOW // planned start/end window
  COST_OVERRIDE // override estimated cost range
  DISABLE_ITEM // exclude from timeline
  ADJUST_REMAINING_LIFE // override remaining years
  NOTE // free-form note affecting reasoning
}

model HomeCapitalTimelineAnalysis {
  id                 String @id @default(uuid())
  homeownerProfileId String
  propertyId         String

  status     HomeCapitalTimelineStatus     @default(READY)
  confidence HomeCapitalTimelineConfidence

  horizonYears Int     @default(10)
  summary      String?

  // Versioned assumptions / overrides used for this run
  inputsSnapshot Json?
  // Full computed timeline for fast render (UI can also use items table)
  timelineJson   Json?

  computedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  homeownerProfile HomeownerProfile @relation(fields: [homeownerProfileId], references: [id], onDelete: Cascade)
  property         Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  items HomeCapitalTimelineItem[]

  @@index([homeownerProfileId])
  @@index([propertyId, computedAt(sort: Desc)])
  @@index([propertyId, status])
  @@map("home_capital_timeline_analyses")
}

model HomeCapitalTimelineItem {
  id         String @id @default(uuid())
  analysisId String
  propertyId String

  inventoryItemId String?
  category        HomeCapitalTimelineCategory
  eventType       HomeCapitalTimelineEventType

  // Predicted window for the event
  windowStart DateTime
  windowEnd   DateTime

  // Estimated cost range (cents)
  estimatedCostMinCents Int?
  estimatedCostMaxCents Int?
  currency              String @default("USD")

  confidence HomeCapitalTimelineConfidence
  priority   HomeCapitalTimelinePriority   @default(MEDIUM)

  why String

  // Optional proof / linkage
  linkedHomeEventId  String?
  evidenceDocumentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  analysis      HomeCapitalTimelineAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  property      Property                    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem?              @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)

  linkedHomeEvent  HomeEvent? @relation(fields: [linkedHomeEventId], references: [id], onDelete: SetNull)
  evidenceDocument Document?  @relation(fields: [evidenceDocumentId], references: [id], onDelete: SetNull)

  // Home Renovation Risk Advisor linkage (back-reference)
  renovationAdvisorSessions HomeRenovationAdvisorSession[]

  @@index([analysisId])
  @@index([propertyId, windowStart])
  @@index([propertyId, category])
  @@index([propertyId, priority])
  @@index([inventoryItemId, windowStart])
  @@map("home_capital_timeline_items")
}

model HomeCapitalTimelineOverride {
  id         String @id @default(uuid())
  propertyId String

  inventoryItemId String?
  type            HomeCapitalTimelineOverrideType

  // Flexible payload:
  // - PLANNED_DATE: { date: "2028-06-01" }
  // - PLANNED_WINDOW: { start: "...", end: "..." }
  // - COST_OVERRIDE: { minCents: 900000, maxCents: 1200000 }
  // - ADJUST_REMAINING_LIFE: { remainingYears: 3 }
  // - DISABLE_ITEM: { disabled: true }
  payload Json

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property      Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)

  @@index([propertyId])
  @@index([inventoryItemId])
  @@index([propertyId, type])
  @@map("home_capital_timeline_overrides")
}

// ============================================================================
// Do Nothing Simulator
// ============================================================================

enum DoNothingSimulationStatus {
  READY
  STALE
  ERROR
}

enum DoNothingSimulationConfidence {
  HIGH
  MEDIUM
  LOW
}

enum DoNothingIncidentLikelihood {
  LOW
  MEDIUM
  HIGH
}

model DoNothingScenario {
  id                 String @id @default(uuid())
  homeownerProfileId String
  propertyId         String

  name          String
  horizonMonths Int    @default(12)

  // User-defined knobs: e.g., { skipMaintenance: true, skipWarranty: true, deductibleStayHigh: true, cashBufferCents: 500000, ... }
  inputOverrides Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  homeownerProfile HomeownerProfile @relation(fields: [homeownerProfileId], references: [id], onDelete: Cascade)
  property         Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  runs DoNothingSimulationRun[]

  @@index([homeownerProfileId])
  @@index([propertyId, horizonMonths])
  @@map("do_nothing_scenarios")
}

model DoNothingSimulationRun {
  id                 String @id @default(uuid())
  homeownerProfileId String
  propertyId         String
  assumptionSetId    String?

  scenarioId String?

  status     DoNothingSimulationStatus     @default(READY)
  confidence DoNothingSimulationConfidence

  horizonMonths Int @default(12)

  // Short human summary for UI
  summary String?

  // Versioned assumptions/inputs used by the simulator (baseline risk snapshot, toggles, overrides)
  inputsSnapshot Json?

  // Main computed outputs (risk deltas, cost deltas, incident likelihood, per-category impacts)
  outputsSnapshot Json?

  // Explainability factors: label/detail/impact
  decisionTrace Json?

  // Optional: lightweight structured “next steps” list for UI cards
  nextSteps Json?

  // Key numerics (queryable + sortable for dashboards)
  riskScoreDelta            Int? // signed change vs baseline (if you have a numeric risk score)
  expectedCostDeltaCentsMin Int? // min additional expected cost due to inaction (cents)
  expectedCostDeltaCentsMax Int? // max additional expected cost due to inaction (cents)

  incidentLikelihood DoNothingIncidentLikelihood?

  computedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  homeownerProfile HomeownerProfile @relation(fields: [homeownerProfileId], references: [id], onDelete: Cascade)
  property         Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  assumptionSet    AssumptionSet?   @relation(fields: [assumptionSetId], references: [id], onDelete: SetNull)

  scenario DoNothingScenario? @relation(fields: [scenarioId], references: [id], onDelete: SetNull)

  @@index([homeownerProfileId])
  @@index([assumptionSetId])
  @@index([propertyId, computedAt(sort: Desc)])
  @@index([propertyId, horizonMonths])
  @@index([propertyId, status])
  @@index([scenarioId, computedAt(sort: Desc)])
  @@map("do_nothing_simulation_runs")
}

