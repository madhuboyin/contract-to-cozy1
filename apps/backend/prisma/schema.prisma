  MAY_BE_REQUIRED
  NOT_REQUIRED
  UNKNOWN
  DATA_UNAVAILABLE
}

enum PropertyTaxReassessmentTriggerType {
  ON_PERMIT
  ON_COMPLETION
  NEXT_ASSESSMENT_CYCLE
  ON_SALE
  JURISDICTION_SPECIFIC
  UNKNOWN
  DATA_UNAVAILABLE
}

enum RenovationProjectCostSource {
  USER_INPUT
  MEDIAN_ASSUMPTION
  REGIONAL_ESTIMATE
  PROVIDER_ESTIMATE
  UNKNOWN
}

enum AdvisorRiskLevel {
  LOW
  MODERATE
  HIGH
  CRITICAL
  UNKNOWN
}

enum AdvisorDataSourceType {
  API_VERIFIED
  CURATED_DATASET
  REGIONAL_INTERPOLATION
  INTERNAL_RULE
  USER_PROVIDED
  MANUAL_OVERRIDE
  UNKNOWN
}

enum RenovationJurisdictionLevel {
  STATE
