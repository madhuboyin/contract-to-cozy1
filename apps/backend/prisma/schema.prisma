// Core article record for Knowledge Hub / SEO / in-app education
model KnowledgeArticle {
  id       String  @id @default(uuid())
  slug     String  @unique
  title    String
  subtitle String?
  excerpt  String?

  status      KnowledgeArticleStatus @default(DRAFT)
  articleType KnowledgeArticleType   @default(EDUCATIONAL)

  // Hero / editorial metadata
  heroTitle       String?
  heroDescription String?
  heroImageUrl    String?
  coverDocumentId String?

  // SEO
  seoTitle       String?
  seoDescription String?
  seoKeywords    String[] @default([])
  canonicalUrl   String?

  // Editorial controls
  readingMinutes Int?
  featured       Boolean   @default(false)
  evergreenScore Int?
  sortOrder      Int       @default(0)
  schemaVersion  String    @default("v1")
  publishedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  coverDocument Document? @relation("KnowledgeArticleCoverDocument", fields: [coverDocumentId], references: [id], onDelete: SetNull)

  sections      KnowledgeArticleSection[]
  categoryLinks KnowledgeArticleCategory[]
  tagLinks      KnowledgeArticleTag[]
  toolLinks     KnowledgeArticleToolLink[]
  ctaLinks      KnowledgeArticleCta[]

  relatedFrom KnowledgeArticleRelation[] @relation("KnowledgeArticleRelationSource")
  relatedTo   KnowledgeArticleRelation[] @relation("KnowledgeArticleRelationTarget")

  audienceRules KnowledgeAudienceRule[]
  events        KnowledgeArticleEvent[]

  @@index([status, publishedAt])
  @@index([articleType, status])
  @@index([featured, sortOrder])
  @@index([coverDocumentId])
  @@map("knowledge_articles")
}

// Structured sections so frontend can inject cards / FAQs / tool embeds / CTA blocks
model KnowledgeArticleSection {
  id        String @id @default(uuid())
  articleId String

  sectionType KnowledgeSectionType @default(TEXT)
  title       String?
  body        String?
  dataJson    Json?
  sortOrder   Int                  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  article KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  toolLinks KnowledgeArticleToolLink[]
  ctaLinks  KnowledgeArticleCta[]
  events    KnowledgeArticleEvent[]

  @@index([articleId, sortOrder])
  @@map("knowledge_article_sections")
}

// High-level grouping: Maintenance / Insurance / Climate / Property Value, etc.
model KnowledgeCategory {
  id          String  @id @default(dbgenerated("(gen_random_uuid())::text"))
  slug        String  @unique
  name        String
  description String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Relations
  articles KnowledgeArticleCategory[]

  @@index([isActive, sortOrder])
  @@map("knowledge_categories")
}

// Granular tagging: roof-age / hvac-age / climate-risk / curb-appeal, etc.
