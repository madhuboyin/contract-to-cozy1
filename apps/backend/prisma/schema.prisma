  updatedAt DateTime @updatedAt

  @@index([homeSavingsAccountId])
  @@index([homeSavingsOpportunityId])
  @@index([bookingId])
  @@index([type])
  @@index([propertyId]) // NEW INDEX
  @@index([propertyId, type, createdAt(sort: Desc)])
  @@index([verificationStatus, createdAt(sort: Desc)])
  @@index([sha256])
  @@index([warrantyId]) // NEW INDEX
  @@index([policyId]) // NEW INDEX
  @@index([inventoryItemId]) // NEW INDEX
  @@map("documents")
}

