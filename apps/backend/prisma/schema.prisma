// -- Models --

// Canonical digital twin record — one per property.
model HomeDigitalTwin {
  id         String @id @default(uuid())
  propertyId String @unique

  status            HomeDigitalTwinStatus @default(DRAFT)
  version           Int                   @default(1)
  completenessScore Float?
  confidenceScore   Float?
  lastComputedAt    DateTime?
  lastSyncedAt      DateTime?
  notes             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  property        Property                 @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  components      HomeTwinComponent[]
  scenarios       HomeTwinScenario[]
  dataQuality     HomeTwinDataQuality[]
  computationRuns HomeTwinComputationRun[]

  @@index([propertyId])
  @@index([status])
  @@map("home_digital_twins")
}

// Models a major system or component tracked within the digital twin.
model HomeTwinComponent {
  id            String @id @default(uuid())
  digitalTwinId String
  propertyId    String

  componentType     HomeTwinComponentType
  label             String? // e.g. "Main HVAC", "Upper Floor AC"
  status            HomeTwinComponentStatus @default(ESTIMATED)
  sourceType        HomeTwinSourceType      @default(MANUAL)
  sourceReferenceId String? // optional FK pointer to another domain model

  installYear                   Int?
  estimatedAgeYears             Float?
  usefulLifeYears               Float?
  conditionScore                Float?
  failureRiskScore              Float?
  replacementCostEstimate       Decimal?  @db.Decimal(12, 2)
  annualOperatingCostEstimate   Decimal?  @db.Decimal(12, 2)
  annualMaintenanceCostEstimate Decimal?  @db.Decimal(12, 2)
  energyImpactScore             Float?
  resilienceImpactScore         Float?
  confidenceScore               Float?
  isUserConfirmed               Boolean   @default(false)
  metadata                      Json?
  lastModeledAt                 DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  digitalTwin HomeDigitalTwin @relation(fields: [digitalTwinId], references: [id], onDelete: Cascade)
  property    Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([digitalTwinId, componentType])
  @@index([digitalTwinId, status])
  @@index([propertyId, componentType])
  @@map("home_twin_components")
}

// A saved "what if" scenario against a property's digital twin.
model HomeTwinScenario {
  id              String  @id @default(uuid())
  digitalTwinId   String
  propertyId      String
  createdByUserId String?

  name             String
  scenarioType     HomeTwinScenarioType
  status           HomeTwinScenarioStatus @default(DRAFT)
  description      String?
  inputPayload     Json // scenario assumptions
  baselineSnapshot Json? // optional state summary at creation time
  isPinned         Boolean                @default(false)
  isArchived       Boolean                @default(false)
  lastComputedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  digitalTwin HomeDigitalTwin          @relation(fields: [digitalTwinId], references: [id], onDelete: Cascade)
  property    Property                 @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdBy   User?                    @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  impacts     HomeTwinScenarioImpact[]

  // Home Renovation Risk Advisor linkage (back-reference)
  renovationAdvisorSessions HomeRenovationAdvisorSession[]

  @@index([digitalTwinId, status])
  @@index([propertyId, createdAt])
  @@index([createdByUserId, createdAt])
  @@map("home_twin_scenarios")
}

// Normalized computed impact outputs for a saved scenario.
model HomeTwinScenarioImpact {
  id         String @id @default(uuid())
  scenarioId String

  impactType      HomeTwinImpactType
  valueNumeric    Float?
  valueText       String?
  valueJson       Json?
  unit            String? // e.g. USD, YEARS, PERCENT, SCORE
  direction       HomeTwinImpactDirection @default(UNKNOWN)
  confidenceScore Float?
  sortOrder       Int                     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  scenario HomeTwinScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([scenarioId, impactType])
  @@index([scenarioId, sortOrder])
  @@map("home_twin_scenario_impacts")
}

// Tracks data quality and completeness at the twin level.
model HomeTwinDataQuality {
  id            String @id @default(uuid())
  digitalTwinId String

  dimension       HomeTwinDataQualityDimension
  status          HomeTwinDataQualityStatus    @default(UNKNOWN)
  score           Float?
  missingFields   Json?
  notes           String?
  lastEvaluatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  digitalTwin HomeDigitalTwin @relation(fields: [digitalTwinId], references: [id], onDelete: Cascade)

  @@unique([digitalTwinId, dimension])
  @@index([digitalTwinId, dimension])
  @@map("home_twin_data_quality")
}

// Tracks computation/sync attempts for observability.
model HomeTwinComputationRun {
  id            String @id @default(uuid())
  digitalTwinId String

  runType      HomeTwinRunType
  status       HomeTwinRunStatus @default(QUEUED)
  startedAt    DateTime          @default(now())
  completedAt  DateTime?
  errorMessage String?
  summary      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  digitalTwin HomeDigitalTwin @relation(fields: [digitalTwinId], references: [id], onDelete: Cascade)

  @@index([digitalTwinId])
  @@index([digitalTwinId, status])
  @@index([startedAt])
  @@map("home_twin_computation_runs")
}

// ============================================================================
// NEIGHBORHOOD INTELLIGENCE ENGINE — MODELS
// ============================================================================

// Stores detected external infrastructure or planning events near a property.
model NeighborhoodEvent {
  id String @id @default(cuid())

  eventType   NeighborhoodEventType
  title       String
  description String?

  latitude  Float
  longitude Float

  city    String?
  state   String?
  country String?

  sourceName String?
  sourceUrl  String?

  announcedDate     DateTime?
  expectedStartDate DateTime?
  expectedEndDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  impacts         NeighborhoodImpact[]
  propertyMatches PropertyNeighborhoodEvent[]
  demographics    DemographicImpact[]

  @@index([eventType])
  @@index([latitude, longitude])
  @@map("neighborhood_events")
}

// Links a property to nearby neighborhood events.
model PropertyNeighborhoodEvent {
  id String @id @default(cuid())

  propertyId String
  eventId    String

  distanceMiles Float

  impactScore Int?

  createdAt DateTime @default(now())

  property Property          @relation(fields: [propertyId], references: [id])
  event    NeighborhoodEvent @relation(fields: [eventId], references: [id])

  @@index([propertyId])
  @@index([eventId])
  @@map("property_neighborhood_events")
}

// Stores predicted impacts from a neighborhood event.
model NeighborhoodImpact {
  id String @id @default(cuid())

  eventId String

  category  ImpactCategory
  direction ImpactDirection

  description String?

  confidence Float?

  createdAt DateTime @default(now())

  event NeighborhoodEvent @relation(fields: [eventId], references: [id])

  @@index([eventId])
  @@map("neighborhood_impacts")
}

// Stores predicted demographic shifts from a neighborhood event.
model DemographicImpact {
  id String @id @default(cuid())

  eventId String

  segment DemographicSegment

  description String?

  confidence Float?

  createdAt DateTime @default(now())

  event NeighborhoodEvent @relation(fields: [eventId], references: [id])

  @@index([eventId])
  @@map("demographic_impacts")
}

// Tracks ingestion scan runs of public planning/infrastructure datasets.
model NeighborhoodScanJob {
  id String @id @default(cuid())

  dataSource String
  status     String

  recordsFound Int?
  recordsSaved Int?

  startedAt   DateTime
  completedAt DateTime?

  createdAt DateTime @default(now())

  @@index([status])
  @@index([dataSource])
  @@map("neighborhood_scan_jobs")
}

// ============================================================================
// ADMIN ANALYTICS LAYER
// ============================================================================

// Enum: property activation lifecycle
enum PropertyActivationStatus {
  NOT_STARTED
  IN_PROGRESS
  ACTIVATED
}

// Enum: standardized event taxonomy for raw product analytics events
enum ProductAnalyticsEventType {
  PROPERTY_CREATED
  PROPERTY_UPDATED
  PROPERTY_ACTIVATED
  DASHBOARD_VIEWED
  FEATURE_OPENED
  SYSTEM_ADDED
  SYSTEM_UPDATED
  MAINTENANCE_ITEM_CREATED
  MAINTENANCE_ITEM_COMPLETED
  INCIDENT_CREATED
  INCIDENT_VIEWED
  CLAIM_CREATED
  CLAIM_VIEWED
  HIDDEN_ASSET_VIEWED
  HIDDEN_ASSET_REFRESHED
  NEGOTIATION_SCENARIO_LAUNCHED
  HOME_PULSE_VIEWED
  DIGITAL_TWIN_VIEWED
  ARTICLE_VIEWED
  DECISION_GUIDED
  ACTION_COMPLETED
  DOCUMENT_UPLOADED
  INVENTORY_ITEM_CREATED
  RISK_VIEWED
  TOOL_USED
  ADMIN_ANALYTICS_VIEWED
  OUTCOME_GENERATED
  OUTCOME_ACTION_TAKEN
}

// Enum: cohort type for retention/activation cohort snapshots
enum AnalyticsCohortType {
  PROPERTY_CREATED_MONTH
  PROPERTY_ACTIVATED_MONTH
  USER_SIGNUP_MONTH
}

// Append-only raw product analytics event log.
// Source of truth for detailed usage, value, and workflow analytics.
model ProductAnalyticsEvent {
  id        String                    @id @default(uuid())
  eventType ProductAnalyticsEventType
  eventName String?

  userId     String?
  propertyId String?

  moduleKey  String?
  featureKey String?
  screenKey  String?
  sessionKey String?

  // Origin surface (e.g. dashboard, home_tools, automation, admin)
  source String?

  // Date-only bucket for efficient day-level aggregation
  eventDate DateTime? @db.Date

  occurredAt   DateTime
  metadataJson Json?

  valueNumeric Float?
  valueText    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([eventType])
  @@index([userId])
  @@index([propertyId])
  @@index([moduleKey])
  @@index([featureKey])
  @@index([occurredAt])
  @@index([propertyId, occurredAt])
  @@index([userId, occurredAt])
  @@index([eventType, occurredAt])
  @@index([featureKey, occurredAt])
  @@map("product_analytics_events")
}

// Aggregated daily analytics per property.
// Keeps admin dashboards fast without scanning raw events.
model PropertyAnalyticsDailyRollup {
  id         String   @id @default(uuid())
  propertyId String
  rollupDate DateTime @db.Date

  isActivated                 Boolean @default(false)
  interactionCount            Int     @default(0)
  featureOpenCount            Int     @default(0)
  toolUsageCount              Int     @default(0)
  dashboardViewCount          Int     @default(0)
  decisionGuidedCount         Int     @default(0)
  incidentCount               Int     @default(0)
  claimCount                  Int     @default(0)
  maintenanceActionCount      Int     @default(0)
  articleViewCount            Int     @default(0)
  hiddenAssetInteractionCount Int     @default(0)
  homePulseViewCount          Int     @default(0)
  digitalTwinViewCount        Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, rollupDate])
  @@index([propertyId])
  @@index([rollupDate])
  @@index([rollupDate, isActivated])
  @@map("property_analytics_daily_rollups")
}

// Daily platform-level usage aggregates per module/feature.
model FeatureAnalyticsDailyRollup {
  id         String   @id @default(uuid())
  rollupDate DateTime @db.Date
  moduleKey  String
  featureKey String

  openCount           Int @default(0)
  interactionCount    Int @default(0)
  uniqueUserCount     Int @default(0)
  uniquePropertyCount Int @default(0)
  decisionGuidedCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([rollupDate, moduleKey, featureKey])
  @@index([rollupDate])
  @@index([moduleKey])
  @@index([featureKey])
  @@map("feature_analytics_daily_rollups")
}

// Top-level daily platform metrics snapshot for fast admin dashboard rendering.
model AdminAnalyticsDailySnapshot {
  id           String   @id @default(uuid())
  snapshotDate DateTime @unique @db.Date

  totalUsers                    Int
  totalAdminUsers               Int?
  totalProperties               Int
  totalActivatedHomes           Int
  weeklyActiveHomes             Int
  monthlyActiveHomes            Int
  avgMonthlyInteractionsPerHome Float?
  decisionsGuidedCount          Int
  activeFeatureCount            Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([snapshotDate])
  @@map("admin_analytics_daily_snapshots")
}

// Precomputed activation/retention cohort metrics.
// Avoids recalculating cohort windows on every admin dashboard load.
model AnalyticsCohortSnapshot {
  id           String              @id @default(uuid())
  cohortKey    String
  cohortType   AnalyticsCohortType
  snapshotDate DateTime            @db.Date

  cohortSize          Int
  activatedCount      Int
  retainedWeek1Count  Int?
  retainedWeek4Count  Int?
  retainedMonth3Count Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cohortType, cohortKey, snapshotDate])
  @@index([cohortType, snapshotDate])
  @@index([snapshotDate])
  @@map("analytics_cohort_snapshots")
}

// ============================================================================
// HOME HABIT COACH
// ============================================================================

// Master catalog of reusable habit definitions shared across all properties.
// This is the template layer — not property-specific.
model HabitTemplate {
  id  String @id @default(uuid())
  key String @unique // stable slug, e.g. "hvac_filter_replace_monthly"

  title            String
  shortDescription String?
  description      String?

  category   HabitCategory
  cadence    HabitCadence
  difficulty HabitDifficulty
  impactType HabitImpactType

  estimatedMinutes Int?
  isActive         Boolean @default(true)
  isSeasonal       Boolean @default(false)
  priority         Int? // lower = higher priority; null = unranked

  tipText                String? // guidance shown alongside the habit
  completionNoteTemplate String? // suggested note prompt when user completes
  iconKey                String? // future UI icon mapping key

  // Flexible targeting rules and metadata for engine use
  targetingRulesJson Json? // conditions under which this habit should be surfaced
  metadataJson       Json? // additional arbitrary metadata

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  propertyHabits PropertyHabit[]

  @@index([category])
  @@index([cadence])
  @@index([isActive])
  @@map("habit_templates")
}

// A habit instance assigned or generated for a specific property.
// Multiple instances of the same template may exist over time (recurrence-safe).
model PropertyHabit {
  id              String @id @default(uuid())
  propertyId      String
  habitTemplateId String

  status           HabitAssignmentStatus @default(ACTIVE)
  generationSource HabitGenerationSource

  // Optional property-scoped overrides for title/description
  titleOverride       String?
  descriptionOverride String?

  // Timing lifecycle fields
  surfacedAt      DateTime  @default(now())
  dueAt           DateTime?
  availableFrom   DateTime?
  expiresAt       DateTime?
  lastActionAt    DateTime?
  lastCompletedAt DateTime?
  snoozedUntil    DateTime?

  // Explainability and scoring
  priorityScore Float?
  reasonSummary String? // short human-readable "why this was suggested"
  reasonJson    Json? // structured engine output: rules matched, signals, weights
  contextJson   Json? // seasonal/property/climate context snapshot at generation time

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property      Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  habitTemplate HabitTemplate @relation(fields: [habitTemplateId], references: [id], onDelete: Restrict)

  actions PropertyHabitAction[]

  @@index([propertyId, status])
  @@index([propertyId, dueAt])
  @@index([propertyId, snoozedUntil])
  @@index([propertyId, createdAt])
  @@index([habitTemplateId])
  @@map("property_habits")
}

// Immutable event log of user or system interactions with a property habit.
// Supports full auditability and habit history replay.
model PropertyHabitAction {
  id              String  @id @default(uuid())
  propertyHabitId String
  propertyId      String
  userId          String? // null if system-generated

  actionType         HabitActionType
  note               String? // optional user note on completion/skip
  snoozeUntil        DateTime? // populated when actionType = SNOOZED
  actionMetadataJson Json? // any additional context from the client or engine

  createdAt DateTime @default(now())

  propertyHabit PropertyHabit @relation(fields: [propertyHabitId], references: [id], onDelete: Cascade)
  property      Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([propertyHabitId, createdAt])
  @@index([propertyId, createdAt])
  @@index([userId, createdAt])
  @@index([actionType])
  @@map("property_habit_actions")
}

// Property-scoped preferences controlling habit coach behavior.
// One record per property; created lazily on first preference save.
model PropertyHabitPreference {
  id         String @id @default(uuid())
  propertyId String @unique

  isEnabled             Boolean @default(true)
  preferredSurfaceCount Int? // max habits to surface at once; null = engine default

  snoozeDefaultsJson   Json? // default snooze durations per category, e.g. { "HVAC": 7 }
  quietHoursJson       Json? // future: suppress habit surfacing during certain hours
  hiddenCategoriesJson Json? // HabitCategory values the user has muted
  personalizationJson  Json? // future personalization signals (skill level, goals, etc.)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_habit_preferences")
}

