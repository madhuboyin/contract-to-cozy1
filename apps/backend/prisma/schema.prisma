// HOME PULSE
// ============================================================================

enum MicroActionStatus {
  PENDING
  COMPLETED
  DISMISSED
  EXPIRED
}

enum MicroActionType {
  // Maintenance / safety
  HVAC_FILTER_CHECK
  GFCI_TEST
  SMOKE_CO_TEST
  SUMP_PUMP_TEST
  PIPE_FREEZE_PREP
  STORM_PREP

  // Warranty / inventory / recall
  WARRANTY_EXPIRING
  RECALL_ALERT

  // Financial / rebates
  UTILITY_REBATE
  INSURANCE_REVIEW
}

enum PropertyStreakType {
  DAILY_PULSE_CHECKIN
  MICRO_ACTION_COMPLETED
  NO_OVERDUE_TASKS
}

model PropertyDailySnapshot {
  id         String  @id @default(uuid())
  propertyId String
  userId     String?

  // Daily bucket (DATE semantics)
  snapshotDate DateTime @db.Date

  // Render-ready content for UI/email/push
  payloadJson Json

  // Optional: numeric scores + deltas for analytics/filtering
  scoreJson   Json?
  weatherJson Json?

  microActionId String?
  microAction   PropertyMicroAction? @relation(fields: [microActionId], references: [id], onDelete: SetNull)

  // Optional: if you create a Notification for email/push, link it
  notificationId String?
  notification   Notification? @relation(fields: [notificationId], references: [id], onDelete: SetNull)

  sourceVersion Int      @default(1)
  generatedAt   DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([propertyId, snapshotDate])
  @@index([propertyId, snapshotDate(sort: Desc)])
  @@index([userId, snapshotDate(sort: Desc)])
  @@map("property_daily_snapshots")
}

model PropertyMicroAction {
  id         String  @id @default(uuid())
  propertyId String
  userId     String?

  type   MicroActionType
  status MicroActionStatus @default(PENDING)

  title       String
  description String?
  ctaLabel    String?
  etaMinutes  Int?
  impactScore Int? // ranking score

  // Optional linkage into existing domain objects
  sourceType String? // "PROPERTY_MAINTENANCE_TASK" | "WARRANTY" | "RECALL_MATCH" etc.
  sourceId   String?

  // suppression/dedupe (avoid repeating)
  suppressionKey String? // e.g. "PIPE_FREEZE_PREP:2026-02-16" or hashed

  suggestedAt DateTime  @default(now())
  dueAt       DateTime?
  completedAt DateTime?
  dismissedAt DateTime?

  metaJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  snapshots PropertyDailySnapshot[]

  @@index([propertyId, status, suggestedAt])
  @@index([propertyId, type, suggestedAt])
  @@index([sourceType, sourceId])
  @@index([suppressionKey])
  @@map("property_micro_actions")
}

model PropertyStreak {
  id         String  @id @default(uuid())
  propertyId String
  userId     String?

  streakType   PropertyStreakType
  currentCount Int                @default(0)
  bestCount    Int                @default(0)

  lastActiveDate DateTime  @db.Date
  startedAt      DateTime?

  metaJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([propertyId, streakType])
  @@index([propertyId, streakType])
  @@index([userId, streakType])
  @@map("property_streaks")
}

// ============================================================================
// Home Savings Check
// ============================================================================

enum HomeSavingsBillingCadence {
  MONTHLY
  QUARTERLY
  ANNUAL
  OTHER
}

enum HomeSavingsAccountStatus {
  ACTIVE
  INACTIVE
  UNKNOWN
}

enum HomeSavingsOpportunityStatus {
  NEW
  VIEWED
  DISMISSED
  SAVED
  APPLIED
  SWITCHED
  EXPIRED
}

enum HomeSavingsConfidence {
  HIGH
  MEDIUM
  LOW
}

enum HomeSavingsRunTrigger {
  MANUAL
  SCHEDULED
  EVENT_DRIVEN
}

model HomeSavingsRun {
  id                 String  @id @default(uuid())
  homeownerProfileId String
  propertyId         String?

  trigger HomeSavingsRunTrigger @default(MANUAL)

  // Inputs used to compute comparisons
  inputsJson  Json?
  // Summary of outputs (totals, counts)
  summaryJson Json?

  ranAt DateTime @default(now())

  homeownerProfile HomeownerProfile @relation(fields: [homeownerProfileId], references: [id], onDelete: Cascade)
  property         Property?        @relation(fields: [propertyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([homeownerProfileId, ranAt(sort: Desc)])
  @@index([propertyId, ranAt(sort: Desc)])
  @@map("home_savings_runs")
}

model HomeSavingsOpportunity {
  id                 String  @id @default(uuid())
  homeownerProfileId String
  propertyId         String?

  categoryKey String
  accountId   String? // the current plan this is based on
  status      HomeSavingsOpportunityStatus @default(NEW)
  confidence  HomeSavingsConfidence        @default(MEDIUM)

  headline      String // "Switch to Verizon Fios and save $20/month"
  detail        String?
  rationaleJson Json? // why we think you’re overpaying

  // Savings math (store both monthly and annual)
  estimatedMonthlySavings Decimal? @db.Decimal(12, 2)
  estimatedAnnualSavings  Decimal? @db.Decimal(12, 2)
  currency                String   @default("USD")

  // Recommended alternative(s)
  recommendedProviderName String?
  recommendedPlanName     String?
  offerJson               Json? // multiple offers, rates, fees, promo periods, etc.

  // Links / next action
  actionUrl String?
  expiresAt DateTime?

  generatedAt DateTime @default(now())

  homeownerProfile HomeownerProfile    @relation(fields: [homeownerProfileId], references: [id], onDelete: Cascade)
  property         Property?           @relation(fields: [propertyId], references: [id])
  account          HomeSavingsAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  documents Document[] @relation("HomeSavingsOpportunityDocuments")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([homeownerProfileId, categoryKey, status])
  @@index([propertyId, categoryKey, status])
  @@index([accountId])
  @@map("home_savings_opportunities")
}

model HomeSavingsAccount {
  id                 String  @id @default(uuid())
  homeownerProfileId String
  propertyId         String?

  categoryKey String // FK by convention to HomeSavingsCategory.key
  status      HomeSavingsAccountStatus @default(ACTIVE)

  providerName        String?
  planName            String?
  accountNumberMasked String? // last4 or masked token

  // Cost inputs
  billingCadence HomeSavingsBillingCadence @default(MONTHLY)
  amount         Decimal?                  @db.Decimal(12, 2) // current recurring amount
  currency       String                    @default("USD")

  // Contract / dates
  startDate       DateTime?
  renewalDate     DateTime?
  contractEndDate DateTime?

  // Usage + plan details (internet speed, kWh usage, rate type, etc.)
  usageJson       Json?
  planDetailsJson Json?

  // Optional linking to existing canonical entities (for Phase-1 categories)
  insurancePolicyId String?
  warrantyId        String?

  homeownerProfile HomeownerProfile @relation(fields: [homeownerProfileId], references: [id], onDelete: Cascade)
  property         Property?        @relation(fields: [propertyId], references: [id])

  insurancePolicy InsurancePolicy? @relation(fields: [insurancePolicyId], references: [id], onDelete: SetNull)
  warranty        Warranty?        @relation(fields: [warrantyId], references: [id], onDelete: SetNull)

  documents     Document[]               @relation("HomeSavingsAccountDocuments")
  opportunities HomeSavingsOpportunity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([homeownerProfileId, categoryKey])
  @@index([propertyId, categoryKey])
  @@index([insurancePolicyId])
  @@index([warrantyId])
  @@map("home_savings_accounts")
}

model HomeSavingsCategory {
  id          String  @id @default(uuid())
  key         String  @unique // e.g. "INTERNET", "ELECTRICITY_GAS"
  label       String // "Internet", "Electricity & Gas"
  description String?
  isEnabled   Boolean @default(true)
  sortOrder   Int     @default(0)
  metadata    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("home_savings_categories")
}

