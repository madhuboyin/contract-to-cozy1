  CITY
  ZIP
  MULTI_LEVEL
  UNKNOWN
}

enum RenovationPermitType {
  BUILDING
  ELECTRICAL
  PLUMBING
  MECHANICAL
  STRUCTURAL
  ZONING
  OTHER
}

enum RenovationInspectionStageType {
  PLAN_REVIEW
  PRE_CONSTRUCTION
  FOUNDATION
  FRAMING
  ROUGH_IN
  ELECTRICAL
  PLUMBING
  MECHANICAL
  INSULATION
  FINAL
  OTHER
}

enum RenovationLicenseCategoryType {
  GENERAL_CONTRACTOR
  ELECTRICAL
  PLUMBING
  HVAC
  ROOFING
  STRUCTURAL
  SPECIALTY
  OTHER
}

enum TriStateChecklistStatus {
  YES
  NO
  UNKNOWN
}

// --- Models ---

// A. Core session — one per advisor run for a property + renovation scenario.
model HomeRenovationAdvisorSession {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  propertyId      String
  createdByUserId String?

  status         RenovationAdvisorSessionStatus @default(DRAFT)
  renovationType HomeRenovationType

  // Optional label for future "OTHER" type extension
  customRenovationLabel String?

  entryPoint RenovationAdvisorEntryPoint
  flowType   RenovationAdvisorFlowType   @default(EXPLICIT_PRE_PROJECT)

  // Jurisdiction
  jurisdictionLevel         RenovationJurisdictionLevel @default(UNKNOWN)
  jurisdictionState         String?
  jurisdictionCounty        String?
  jurisdictionCity          String?
  postalCode                String?
  normalizedJurisdictionKey String? // e.g. "US-CA-los-angeles-90001"
  addressSnapshotJson       Json? // lightweight address snapshot at time of run

  // Project cost
  projectCostInput          Decimal?                    @db.Decimal(12, 2)
  projectCostSource         RenovationProjectCostSource @default(UNKNOWN)
  projectCostAssumptionNote String?

  // Overall output
  overallConfidence AdvisorConfidenceLevel @default(UNAVAILABLE)
  overallRiskLevel  AdvisorRiskLevel       @default(UNKNOWN)
  overallSummary    String?
  warningsSummary   String?
  nextStepsSummary  String?

  // Versioning for auditability
  disclaimerVersion       String?
  rulesVersion            String?
  calculationVersion      String?
  providerSnapshotVersion String?

  // Flow flags
  isRetroactiveCheck            Boolean @default(false)
  completedModificationReported Boolean @default(false)
  userConfirmedJurisdiction     Boolean @default(false)

  // Lifecycle
  sessionExpiresAt DateTime?
  lastEvaluatedAt  DateTime?
  archivedAt       DateTime?

  // Linkage anchors — real FK where model is stable and exists
  linkedTimelineItemId        String? // -> HomeCapitalTimelineItem.id
  linkedDigitalTwinScenarioId String? // -> HomeTwinScenario.id

  // String anchors — FK targets not yet modeled in this schema version
  linkedRiskEntityId      String? // future: risk item / factor id
  linkedTcoEntityId       String? // future: TCO snapshot id
  linkedBreakEvenEntityId String? // future: break-even scenario id

  // Relations
  property                  Property                 @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdBy                 User?                    @relation("RenovationAdvisorSessionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  linkedTimelineItem        HomeCapitalTimelineItem? @relation(fields: [linkedTimelineItemId], references: [id], onDelete: SetNull)
  linkedDigitalTwinScenario HomeTwinScenario?        @relation(fields: [linkedDigitalTwinScenarioId], references: [id], onDelete: SetNull)

  // Child outputs
  permitOutput        HomeRenovationPermitOutput?
  taxImpactOutput     HomeRenovationTaxImpactOutput?
  licensingOutput     HomeRenovationLicensingOutput?
  assumptions         HomeRenovationAdvisorAssumption[]
  dataPoints          HomeRenovationAdvisorDataPoint[]
  complianceChecklist HomeRenovationComplianceChecklist?

  @@index([propertyId, createdAt])
  @@index([propertyId, renovationType])
  @@index([createdByUserId, createdAt])
  @@index([normalizedJurisdictionKey])
  @@index([status])
  @@index([isRetroactiveCheck])
  @@map("home_renovation_advisor_sessions")
}

// C. Permit output — 1:1 with session.
model HomeRenovationPermitOutput {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  advisorSessionId String @unique

  requirementStatus PermitRequirementStatus @default(UNKNOWN)
  confidenceLevel   AdvisorConfidenceLevel  @default(UNAVAILABLE)
  confidenceReason  String?

  permitCostMin         Decimal? @db.Decimal(12, 2)
  permitCostMax         Decimal? @db.Decimal(12, 2)
  permitTimelineMinDays Int?
  permitTimelineMaxDays Int?

  applicationPortalUrl   String?
  applicationPortalLabel String?
  permitSummary          String?

  dataAvailable      Boolean               @default(false)
  sourceType         AdvisorDataSourceType @default(UNKNOWN)
  sourceLabel        String?
  sourceReferenceUrl String?
  sourceRefreshedAt  DateTime?

  rawSourcePayloadJson Json?
  notes                String?

  advisorSession   HomeRenovationAdvisorSession          @relation(fields: [advisorSessionId], references: [id], onDelete: Cascade)
  permitTypes      HomeRenovationPermitTypeRequirement[]
  inspectionStages HomeRenovationInspectionStage[]

  @@index([advisorSessionId])
  @@map("home_renovation_permit_outputs")
}

// Permit type child — many per permit output.
model HomeRenovationPermitTypeRequirement {
  id             String @id @default(uuid())
  permitOutputId String

  permitType      RenovationPermitType
  isRequired      Boolean                @default(false)
  confidenceLevel AdvisorConfidenceLevel @default(UNAVAILABLE)
  note            String?
  displayOrder    Int                    @default(0)

  createdAt DateTime @default(now())

  permitOutput HomeRenovationPermitOutput @relation(fields: [permitOutputId], references: [id], onDelete: Cascade)

  @@index([permitOutputId])
  @@map("home_renovation_permit_type_requirements")
}

// Inspection stage child — many per permit output.
model HomeRenovationInspectionStage {
  id             String @id @default(uuid())
  permitOutputId String

  inspectionStageType RenovationInspectionStageType
  isLikelyRequired    Boolean                       @default(false)
  note                String?
  displayOrder        Int                           @default(0)

  createdAt DateTime @default(now())

  permitOutput HomeRenovationPermitOutput @relation(fields: [permitOutputId], references: [id], onDelete: Cascade)

  @@index([permitOutputId])
  @@map("home_renovation_inspection_stages")
}

// D. Tax impact output — 1:1 with session.
model HomeRenovationTaxImpactOutput {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  advisorSessionId String @unique

  confidenceLevel  AdvisorConfidenceLevel @default(UNAVAILABLE)
  confidenceReason String?

  assessedValueIncreaseMin Decimal? @db.Decimal(12, 2)
  assessedValueIncreaseMax Decimal? @db.Decimal(12, 2)
  annualTaxIncreaseMin     Decimal? @db.Decimal(12, 2)
  annualTaxIncreaseMax     Decimal? @db.Decimal(12, 2)
  monthlyTaxIncreaseMin    Decimal? @db.Decimal(12, 2)
  monthlyTaxIncreaseMax    Decimal? @db.Decimal(12, 2)

  reassessmentTriggerType     PropertyTaxReassessmentTriggerType @default(UNKNOWN)
  reassessmentTimelineSummary String?
  reassessmentRuleSummary     String?
  plainLanguageSummary        String?

  // Stored for audit/explainability
  millageRateSnapshot Decimal? @db.Decimal(10, 6)
  taxModelRegion      String?
  valueUpliftMethod   String?

  dataAvailable      Boolean               @default(false)
  sourceType         AdvisorDataSourceType @default(UNKNOWN)
  sourceLabel        String?
  sourceReferenceUrl String?
  sourceRefreshedAt  DateTime?

  rawSourcePayloadJson Json?
  notes                String?

  advisorSession HomeRenovationAdvisorSession @relation(fields: [advisorSessionId], references: [id], onDelete: Cascade)

  @@index([advisorSessionId])
  @@map("home_renovation_tax_impact_outputs")
}

// E. Licensing output — 1:1 with session.
model HomeRenovationLicensingOutput {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  advisorSessionId String @unique

  requirementStatus ContractorLicenseRequirementStatus @default(UNKNOWN)
  confidenceLevel   AdvisorConfidenceLevel             @default(UNAVAILABLE)
  confidenceReason  String?

  consequenceSummary    String?
  verificationToolUrl   String?
  verificationToolLabel String?
  plainLanguageSummary  String?

  dataAvailable      Boolean               @default(false)
  sourceType         AdvisorDataSourceType @default(UNKNOWN)
  sourceLabel        String?
  sourceReferenceUrl String?
  sourceRefreshedAt  DateTime?

  rawSourcePayloadJson Json?
  notes                String?

  advisorSession    HomeRenovationAdvisorSession               @relation(fields: [advisorSessionId], references: [id], onDelete: Cascade)
  licenseCategories HomeRenovationLicenseCategoryRequirement[]

  @@index([advisorSessionId])
  @@map("home_renovation_licensing_outputs")
}

// License category child — many per licensing output.
model HomeRenovationLicenseCategoryRequirement {
  id                String @id @default(uuid())
  licensingOutputId String

  licenseCategoryType RenovationLicenseCategoryType
  isApplicable        Boolean                       @default(false)
  confidenceLevel     AdvisorConfidenceLevel        @default(UNAVAILABLE)
  note                String?
  displayOrder        Int                           @default(0)

  createdAt DateTime @default(now())

  licensingOutput HomeRenovationLicensingOutput @relation(fields: [licensingOutputId], references: [id], onDelete: Cascade)

  @@index([licensingOutputId])
  @@map("home_renovation_license_category_requirements")
}

// F. Assumptions — explicit inputs/fallbacks used during calculation.
model HomeRenovationAdvisorAssumption {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  advisorSessionId String

  assumptionKey         String // e.g. "median_project_cost", "county_tax_rule_fallback"
  assumptionLabel       String // human-readable label for UI
  assumptionValueText   String?
  assumptionValueNumber Decimal? @db.Decimal(18, 4) // nullable numeric value
  assumptionUnit        String? // e.g. "USD", "percent", "days"

  sourceType      AdvisorDataSourceType  @default(UNKNOWN)
  confidenceLevel AdvisorConfidenceLevel @default(UNAVAILABLE)
  rationale       String?

  isUserVisible Boolean @default(true)
  displayOrder  Int     @default(0)

  advisorSession HomeRenovationAdvisorSession @relation(fields: [advisorSessionId], references: [id], onDelete: Cascade)

  @@index([advisorSessionId])
  @@index([advisorSessionId, assumptionKey])
  @@map("home_renovation_advisor_assumptions")
}

// G. Field-level data points — per-field explainability and source metadata.
model HomeRenovationAdvisorDataPoint {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  advisorSessionId String

  sectionKey     String // e.g. "permit", "tax", "licensing"
  fieldKey       String // e.g. "permitCostMin", "annualTaxIncreaseMax"
  fieldLabel     String?
  fieldValueText String?

  confidenceLevel    AdvisorConfidenceLevel @default(UNAVAILABLE)
  sourceType         AdvisorDataSourceType  @default(UNKNOWN)
  sourceLabel        String?
  sourceReferenceUrl String?
  sourceRefreshedAt  DateTime?
  freshnessLabel     String? // e.g. "Updated Jan 2025"
  note               String?

  isUserVisible Boolean @default(true)
  displayOrder  Int     @default(0)

  advisorSession HomeRenovationAdvisorSession @relation(fields: [advisorSessionId], references: [id], onDelete: Cascade)

  @@index([advisorSessionId])
  @@index([advisorSessionId, sectionKey])
  @@map("home_renovation_advisor_data_points")
}

// I. Compliance follow-up checklist — supports retroactive compliance flow.
model HomeRenovationComplianceChecklist {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  advisorSessionId String @unique

  permitObtainedStatus         TriStateChecklistStatus @default(UNKNOWN)
  licensedContractorUsedStatus TriStateChecklistStatus @default(UNKNOWN)
  reassessmentReceivedStatus   TriStateChecklistStatus @default(UNKNOWN)
  notes                        String?
  lastReviewedAt               DateTime?

  advisorSession HomeRenovationAdvisorSession @relation(fields: [advisorSessionId], references: [id], onDelete: Cascade)

  @@index([advisorSessionId])
  @@map("home_renovation_compliance_checklists")
}

// ============================================================================
// MORTGAGE REFINANCE RADAR
// ============================================================================

// --- Enums ---

// Current detection state of the refinance radar for a property.
enum RefinanceRadarState {
  CLOSED // No actionable refinance opportunity currently detected
  OPEN // A refinance opportunity window is currently active
}

// Confidence level of a refinance opportunity evaluation.
enum RefinanceConfidenceLevel {
  WEAK // Rate gap exists but savings are marginal or assumptions are uncertain
  GOOD // Meaningful savings detected with reasonable assumptions
  STRONG // Clear, high-confidence savings window with solid inputs
}

// Source of a mortgage rate market snapshot.
enum MortgageRateSource {
  FREDDIE_MAC // Freddie Mac Primary Mortgage Market Survey
  FRED // St. Louis Fed FRED economic data
  MANUAL // Manually entered by an admin or operator
  IMPORTED // Imported from a third-party data pipeline
}

// Loan term used in a refinance scenario comparison.
enum RefinanceScenarioTerm {
  THIRTY_YEAR
  TWENTY_YEAR
  FIFTEEN_YEAR
}

// --- Models ---

// A. Periodic market mortgage rate snapshot.
// Used as the market-rate input for radar evaluations and trend analysis.
model MortgageRateSnapshot {
  id           String             @id @default(uuid())
  date         DateTime           @db.Date
  rate30yr     Float // e.g. 6.875 (percent, not decimal fraction)
  rate15yr     Float // e.g. 6.125
  source       MortgageRateSource
  sourceRef    String? // External version/release reference (e.g. "2024-W12")
  metadataJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Back-relations from radar state records that reference this snapshot
  radarStates PropertyRefinanceRadarState[] @relation("LastRateSnapshot")

  @@unique([source, date])
  @@index([date(sort: Desc)])
  @@index([source])
  @@index([source, date(sort: Desc)])
  @@map("mortgage_rate_snapshots")
}

// B. A refinance opportunity evaluation result for a specific property.
// Multiple records accumulate over time — supports history and trend analysis.
model RefinanceOpportunity {
  id         String @id @default(uuid())
  propertyId String

  currentRate Float // Homeowner's existing mortgage rate (percent)
  marketRate  Float // Prevailing market rate used in evaluation (percent)
  rateGap     Float // currentRate - marketRate (percent)

  loanBalance     Decimal @db.Decimal(12, 2) // Estimated remaining principal
  monthlySavings  Decimal @db.Decimal(12, 2)
  breakEvenMonths Int // Months to recoup closing costs
  lifetimeSavings Decimal @db.Decimal(12, 2)

  confidenceLevel RefinanceConfidenceLevel
  radarState      RefinanceRadarState

  evaluationDate DateTime  @db.Date
  triggerDate    DateTime? // When CLOSED → OPEN transition was first detected

  closingCostAssumption Decimal? @db.Decimal(12, 2)
  remainingTermMonths   Int? // Months left on current loan at time of evaluation

  metadataJson Json? // Assumptions and inputs used in evaluation

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  // Back-reference from the radar state that treats this as the current opportunity
  radarStateCurrentRef PropertyRefinanceRadarState? @relation("CurrentRefinanceOpportunity")

  @@index([propertyId, createdAt(sort: Desc)])
  @@index([propertyId, radarState])
  @@index([propertyId, evaluationDate(sort: Desc)])
  @@index([confidenceLevel])
  @@map("refinance_opportunities")
}

// C. Current refinance radar state for a property — one record per property.
// Provides fast lookup of current state without scanning opportunity history.
model PropertyRefinanceRadarState {
  id         String @id @default(uuid())
  propertyId String @unique

  radarState RefinanceRadarState @default(CLOSED)

  // Optional pointer to the RefinanceOpportunity that opened the current window
  currentOpportunityId String? @unique
  // Optional pointer to the most recent rate snapshot used in evaluation
  lastRateSnapshotId   String?

  lastEvaluatedAt DateTime?
  lastOpenedAt    DateTime?
  lastClosedAt    DateTime?

  metadataJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property           Property              @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  currentOpportunity RefinanceOpportunity? @relation("CurrentRefinanceOpportunity", fields: [currentOpportunityId], references: [id], onDelete: SetNull)
  lastRateSnapshot   MortgageRateSnapshot? @relation("LastRateSnapshot", fields: [lastRateSnapshotId], references: [id], onDelete: SetNull)

  @@index([radarState])
  @@index([lastEvaluatedAt])
  @@map("property_refinance_radar_states")
}

// D. User-run refinance scenario comparison — persisted for later review.
// Follows the same pattern as DoNothingScenario and CoverageScenario.
model RefinanceScenarioSnapshot {
  id         String @id @default(uuid())
  propertyId String

  targetRate  Float // Hypothetical new mortgage rate (percent)
  targetTerm  RefinanceScenarioTerm
  closingCost Decimal               @db.Decimal(12, 2)

  monthlySavings  Decimal? @db.Decimal(12, 2)
  breakEvenMonths Int?
  lifetimeSavings Decimal? @db.Decimal(12, 2)

  isSaved      Boolean @default(false) // User explicitly saved this scenario
  metadataJson Json? // Full assumption set used in scenario run

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, createdAt(sort: Desc)])
  @@index([propertyId, isSaved])
  @@map("refinance_scenario_snapshots")
}

// ============================================================================
// HOME GAZETTE
// ============================================================================
//
// Gazette-owned persistence layer for weekly AI-generated property digests.
// Design principles:
//   - Gazette tables own Gazette artifacts only — not upstream domain data.
//   - Upstream linkage is loose: sourceFeature / sourceEventId / entityType /
//     entityId fields instead of hard FK dependencies on every domain table.
//   - Share tokens are stored in hashed form only (tokenHash, never raw token).
//   - One edition per property per (weekStart, weekEnd) window, enforced by
//     @@unique([propertyId, weekStart, weekEnd]) on GazetteEdition.
// ============================================================================

// ─── Enums ───────────────────────────────────────────────────────────────────

// Overall lifecycle state of a weekly Gazette edition.
enum GazetteEditionStatus {
  DRAFT // Generation in progress or not yet started
  READY // Stories selected and generated; awaiting publication
  PUBLISHED // Delivered to the homeowner
  SKIPPED // Week skipped due to insufficient qualified stories
  FAILED // Generation pipeline encountered an unrecoverable error
}

// Broad editorial category of a story or candidate.
enum GazetteStoryCategory {
  RISK
  MAINTENANCE
  INCIDENT
  CLAIMS
  INSURANCE
  WARRANTY
  FINANCIAL
  REFINANCE
  NEIGHBORHOOD
  SEASONAL
  SCORE
  DIGITAL_TWIN
  GENERAL
}

// Editorial placement priority for a selected story.
enum GazetteStoryPriority {
  HERO // Lead story; only one per edition
  HIGH
  MEDIUM
  LOW
}

// Pipeline stage being executed by a GazetteGenerationJob.
enum GazetteGenerationStage {
  SIGNAL_COLLECTION // Upstream feature data harvested
  CANDIDATE_GENERATION // Raw candidates produced from signals
  RANKING // Candidates scored and ranked
  EDITORIAL_GENERATION // AI prose / headline generation
  VALIDATION // Output quality and safety checks
  PUBLICATION // Edition persisted and delivered
}

// Lifecycle state of a story candidate before selection.
enum GazetteCandidateStatus {
  ACTIVE // In the pool; eligible for selection
  SELECTED // Promoted to a GazetteStory in this edition
  EXCLUDED // Scored but did not meet selection criteria
  EXPIRED // Passed storyDeadline or expiresAt without being selected
}

// Reason a candidate was excluded from a given edition.
enum GazetteExclusionReason {
  LOW_SCORE // Composite score below threshold
  LOW_CONFIDENCE // Confidence score insufficient
  DUPLICATE // Another candidate covers the same event
  EXPIRED // Past deadline or expiry date
  CATEGORY_CAP // Edition already has max stories in this category
  NOT_SHARE_SAFE // Contains content not safe to share externally
  MISSING_DEEP_LINK // No valid action link available
  MISSING_SUPPORTING_FACTS // Insufficient data to support the story claim
  BELOW_NEWSWORTHY_THRESHOLD // Score did not cross the minimum newsworthy bar
}

// State of a public share link for an edition.
enum GazetteShareStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

// AI prose generation status for a story.
enum GazetteAiStatus {
  NOT_REQUESTED // No AI generation was attempted
  GENERATED // AI produced the prose successfully
  FALLBACK_USED // Template or rule-based fallback was used instead
  FAILED // AI generation was attempted but failed
}

// ─── Models ──────────────────────────────────────────────────────────────────

// A. One weekly Gazette edition per property.
// Uniqueness enforced on (propertyId, weekStart, weekEnd).
model GazetteEdition {
  id         String @id @default(uuid())
  propertyId String

  weekStart   DateTime // Monday 00:00:00 UTC of the edition week
  weekEnd     DateTime // Sunday 23:59:59 UTC of the edition week
  publishDate DateTime? // Intended or actual publication timestamp
  status      GazetteEditionStatus @default(DRAFT)

  // Quality gate counters
  minQualifiedNeeded Int @default(4) // Minimum stories needed to publish
  qualifiedCount     Int @default(0) // Candidates that passed the quality bar
  selectedCount      Int @default(0) // Stories actually selected for this edition

  skippedReason String? // Human-readable reason when status = SKIPPED

  // Hero story pointer (denormalised for fast rendering)
  heroStoryId String?

  // Edition-level AI-generated copy
  summaryHeadline String?
  summaryDeck     String?
  tickerJson      Json? // Array of short ticker-style bullets

  generationVersion String? // Pipeline version tag (e.g. "v1.2.0")
  publishedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stories    GazetteStory[]
  candidates GazetteStoryCandidate[]
  traces     GazetteSelectionTrace[]
  jobs       GazetteGenerationJob[]
  shareLinks GazetteShareLink[]

  @@unique([propertyId, weekStart, weekEnd])
  @@index([propertyId, weekStart])
  @@index([status])
  @@map("gazette_editions")
}

// B. A final selected story that appears in a published edition.
// Stories are created by promoting GazetteStoryCandidate records.
model GazetteStory {
  id         String @id @default(uuid())
  editionId  String
  propertyId String

  // Loose upstream linkage — no FK to upstream domain tables
  sourceFeature String // e.g. "INCIDENT", "REFINANCE_RADAR", "NEIGHBORHOOD"
  sourceEventId String? // Upstream event ID if available (informational only)
  storyCategory GazetteStoryCategory
  storyTag      String? // Fine-grained tag within category (e.g. "PIPE_BURST")
  entityType    String // e.g. "Property", "Appliance", "InsurancePolicy"
  entityId      String // ID of the entity in the upstream domain

  // Editorial placement
  priority GazetteStoryPriority @default(MEDIUM)
  rank     Int // 1-based display order within the edition
  isHero   Boolean              @default(false)

  // AI-generated story copy
  headline            String
  dek                 String? // Subheadline / supporting sentence
  summary             String // Main body prose
  supportingFactsJson Json? // Structured data used to generate copy
  rankExplanation     String? // Human-readable explanation of why this story was ranked here

  // Scoring dimensions (copied from candidate at selection time)
  urgencyScore            Float?
  financialImpactEstimate Float?
  confidenceScore         Float?
  noveltyScore            Float?
  engagementScore         Float?
  compositeScore          Float?

  // Action links
  primaryDeepLink   String // Required — in-app deep link for the story action
  secondaryDeepLink String?

  // Share safety flag — controls whether story is included in public share view
  shareSafe Boolean @default(true)

  // AI generation traceability
  aiStatus         GazetteAiStatus @default(NOT_REQUESTED)
  aiModel          String? // e.g. "gemini-1.5-pro"
  aiPromptVersion  String? // Prompt template version tag
  aiValidationJson Json? // Output from validation / guardrail checks

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  edition GazetteEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)

  @@index([editionId, rank])
  @@index([propertyId, storyCategory])
  @@index([entityType, entityId])
  @@map("gazette_stories")
}

// C. A normalised story candidate produced before final selection.
// Candidates survive across editions via noveltyKey deduplication.
// editionId is nullable: candidates may exist before an edition is created.
model GazetteStoryCandidate {
  id         String  @id @default(uuid())
  editionId  String?
  propertyId String

  // Loose upstream linkage
  sourceFeature String
  sourceEventId String?
  storyCategory GazetteStoryCategory
  storyTag      String?
  entityType    String
  entityId      String

  // Inputs for story generation
  headlineHint        String? // Suggested headline (AI will refine)
  supportingFactsJson Json // Structured signals that back this candidate

  // Scoring dimensions (inputs to the ranking engine)
  urgencyScoreInput       Float?
  financialImpactEstimate Float?
  confidenceScore         Float?
  engagementScore         Float?
  noveltyScore            Float?
  compositeScore          Float?

  // Novelty / deduplication
  noveltyKey      String // Stable hash key — identifies this story event across editions
  firstDetectedAt DateTime?
  lastUpdatedAt   DateTime?
  storyDeadline   DateTime? // After this date the story is no longer newsworthy
  expiresAt       DateTime? // Hard expiry for the candidate record

  // Action links
  primaryDeepLink   String
  secondaryDeepLink String?
  shareSafe         Boolean @default(true)

  // Selection outcome
  status               GazetteCandidateStatus  @default(ACTIVE)
  exclusionReason      GazetteExclusionReason?
  exclusionDetail      String? // Free-text detail to supplement exclusionReason
  selectionRank        Int? // Rank assigned if SELECTED
  rankAdjustmentReason String? // Reason if rank was manually or rule-adjusted

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  edition GazetteEdition? @relation(fields: [editionId], references: [id], onDelete: SetNull)

  @@index([propertyId, status])
  @@index([propertyId, noveltyKey])
  @@index([editionId, selectionRank])
  @@index([sourceFeature, entityType, entityId])
  @@map("gazette_story_candidates")
}

// D. Per-candidate selection/ranking trace for explainability.
// Records both included and excluded candidates so the full decision can be audited.
// candidateId is nullable to allow traces for synthetic or inline candidates.
model GazetteSelectionTrace {
  id          String  @id @default(uuid())
  editionId   String
  candidateId String? // FK omitted intentionally — loose linkage for isolation
  propertyId  String

  preScore             Float? // Score before any adjustments
  postScore            Float? // Score after boosts / penalties applied
  finalRank            Int? // Assigned rank (null if excluded)
  included             Boolean // true = selected into edition
  exclusionReason      GazetteExclusionReason?
  rankAdjustmentReason String?
  rankExplanation      String? // Prose explanation of final rank decision
  traceJson            Json? // Full scoring breakdown for debugging

  createdAt DateTime @default(now())

  edition GazetteEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)

  @@index([editionId, included, finalRank])
  @@index([propertyId, createdAt])
  @@map("gazette_selection_traces")
}

// E. Tracks execution of individual pipeline stages.
// One job record per stage attempt; retries produce new records.
model GazetteGenerationJob {
  id         String  @id @default(uuid())
  editionId  String?
  propertyId String

  stage        GazetteGenerationStage
  status       GazetteEditionStatus   @default(DRAFT)
  startedAt    DateTime?
  finishedAt   DateTime?
  attemptCount Int                    @default(0)
  errorMessage String?
  metricsJson  Json? // Timing, token counts, candidate counts, etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  edition GazetteEdition? @relation(fields: [editionId], references: [id], onDelete: SetNull)

  @@index([propertyId, stage])
  @@index([editionId])
  @@map("gazette_generation_jobs")
}

// F. Secure public share link for a Gazette edition.
// Raw share tokens are NEVER stored — only the SHA-256 hash.
model GazetteShareLink {
  id         String @id @default(uuid())
  editionId  String
  propertyId String

  tokenHash    String             @unique // SHA-256 hash of the raw share token
  status       GazetteShareStatus @default(ACTIVE)
  expiresAt    DateTime?
  revokedAt    DateTime?
  lastViewedAt DateTime?
  viewCount    Int                @default(0)
  metadataJson Json? // e.g. share channel, recipient hint (no PII)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  edition GazetteEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)

  @@index([editionId, status])
  @@index([propertyId, status])
  @@map("gazette_share_links")
}
