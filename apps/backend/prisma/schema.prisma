// Canonical registry for AI Tools / Home Tools / Features / Reports that articles can promote
model ProductTool {
  id               String  @id @default(dbgenerated("(gen_random_uuid())::text"))
  key              String  @unique
  slug             String  @unique
  name             String
  shortDescription String?

  toolType ProductToolType
  status   ProductToolStatus @default(ACTIVE)

  routePath  String?
  iconName   String?
  badgeLabel String?
  sortOrder  Int     @default(0)

  category String?
  metadata Json?

