// ===============================
// SIGNAL SOURCE TAGGING
// ===============================

enum SignalSourceType {
  SCHEDULED // ⏱ Time-based / cron / seasonal
  INTELLIGENCE // 📊 Risk model / AI / prediction
  COVERAGE // 📄 Insurance / warranty derived
  MANUAL // 👤 User initiated
  SENSOR // 🔔 IoT / telemetry
  DOCUMENT // 🧾 OCR/PDF extraction
  EXTERNAL // 🌎 CPSC/NOAA/3rd-party feeds (optional but useful)
}

enum SignalTriggerType {
  RULE // deterministic rule fired
  MODEL // probabilistic model output
  EXTRACTION // OCR/doc parsing
  USER_ACTION // explicit user action
  SCHEDULE // cron/time-based
  INGEST // external feed ingestion
}

enum DerivedFromType {
  RISK_ASSESSMENT
  POLICY
  WARRANTY
  DOCUMENT
  INVENTORY_ITEM
  RECALL_RECORD
  WEATHER_EVENT
  USER_EVENT
}

model SignalProvenance {
  id         String @id @default(uuid())
  propertyId String

  // Core taxonomy
  sourceType  SignalSourceType
  triggerType SignalTriggerType

  // Optional “where it came from”
  sourceSystem  String? // e.g. "coverageLapseJob", "freezeRiskModel", "ocrLabel", "cpscIngest"
  sourceVersion String? // model version, ruleset version, pipeline version
  sourceRunId   String? // jobRunId / batchId / ingestionRunId / workflowRunId

  // Optional linkage to the underlying evidence/inputs
  derivedFromType DerivedFromType? // "RISK_ASSESSMENT" | "POLICY" | "WARRANTY" | "DOCUMENT" | "INVENTORY_ITEM" etc.
  derivedFromId   String? // id of the evidence record
  externalRef     String? // provider id or URL-safe id (e.g., CPSC recall id)

  // Explainability
  label         String? // short UI label override (rare)
  summary       String? // 1-line “why this appeared”
  details       Json? // structured payload: thresholds, features, matched fields, etc.
  confidence    Float? // 0..1 (or 0..100) – pick one convention
  severityScore Float? // optional numeric strength signal separate from confidence

  // Polymorphic target (links provenance to a thing in your system)
  targetType String // "ORCHESTRATED_ACTION" | "INCIDENT" | "NOTIFICATION" | "TASK" | "CLAIM_INSIGHT"
  targetId   String

  createdAt                    DateTime                      @default(now())
  attributions                 SignalAttribution[]
  homeEvents                   HomeEvent[]                   @relation("HomeEventProvenance")
  homeScoreReportEvidenceLinks HomeScoreReportEvidenceLink[]
  guidanceSignals              GuidanceSignal[]

  @@index([propertyId])
  @@index([propertyId, targetType, targetId])
  @@index([targetType, targetId])
  @@index([sourceType])
  @@index([sourceSystem])
}

model SignalAttribution {
  id           String           @id @default(uuid())
  provenanceId String
  provenance   SignalProvenance @relation(fields: [provenanceId], references: [id], onDelete: Cascade)

  rank   Int    @default(0) // 0 = primary
  weight Float? // e.g. contribution score

  @@index([provenanceId])
}

model Signal {
  id         String  @id @default(uuid())
  propertyId String
  roomId     String?
  homeItemId String?

  signalKey   String
  valueNumber Float?
  valueText   String?
  valueJson   Json?
  unit        String?
  confidence  Float?
  sourceModel String
  sourceId    String
  capturedAt  DateTime @default(now())
  validUntil  DateTime?
  version     Int      @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  room     InventoryRoom? @relation(fields: [roomId], references: [id], onDelete: SetNull)
  homeItem HomeItem?      @relation(fields: [homeItemId], references: [id], onDelete: SetNull)

  @@unique([propertyId, signalKey, sourceModel, sourceId, version, capturedAt])
  @@index([propertyId])
  @@index([roomId])
  @@index([homeItemId])
  @@index([signalKey])
  @@index([capturedAt(sort: Desc)])
  @@index([validUntil])
  @@index([sourceModel, sourceId])
  @@index([propertyId, signalKey, capturedAt(sort: Desc)])
  @@map("signals")
}

// =============================================================================
// GUIDANCE ENGINE — DETERMINISTIC RESOLUTION JOURNEY FOUNDATION
// =============================================================================

enum GuidanceIssueDomain {
  // Templates implemented: recall_safety_resolution
  SAFETY
  // Templates implemented: inspection_followup_resolution
  MAINTENANCE
  // Templates implemented: coverage_gap_resolution
  INSURANCE
  // Templates implemented: financial_exposure_resolution, financial_inaction_resolution
  FINANCIAL
  // Templates implemented: asset_lifecycle_resolution
  ASSET_LIFECYCLE
  // Templates implemented: weather_risk_resolution (S6-38: all severe weather families)
  WEATHER
  // Templates implemented: compliance_resolution (S6-37)
  COMPLIANCE
  // Templates implemented: energy_efficiency_resolution (S6-37)
  ENERGY
  // --- Formally out of scope for journey templates; signals route to DEFAULT_TEMPLATE ---
  // CLAIMS: handled by claims-assistance feature (separate from guidance engine)
  CLAIMS
  // MARKET_VALUE: no actionable journey template defined; signals surface as informational
  MARKET_VALUE
  // PRICING, NEGOTIATION, BOOKING: covered by standalone tools, not journey templates
  PRICING
  NEGOTIATION
  BOOKING
  // DOCUMENTATION, NEIGHBORHOOD, ONBOARDING: out of scope for journey templates
  DOCUMENTATION
  NEIGHBORHOOD
  ONBOARDING
  OTHER
}

// IMP-GE-1: Top-level scope category for a guidance journey.
// Phase 1 values: ITEM (inventory item / home asset) and SERVICE (non-item service).
// Extensible — future phases may add: COVERAGE_PLAN, INCIDENT_CASE, SAVINGS_INCENTIVE, DOCUMENT_COMPLIANCE.
enum GuidanceScopeCategory {
  ITEM
  SERVICE
}

// P4-1: Constrains signalIntentFamily to known routing keys.
// Each value maps to exactly one journey template in guidanceTemplateRegistry.ts.
// Adding a new template requires adding its family here first.
enum GuidanceSignalIntentFamily {
  // asset_lifecycle_resolution
  lifecycle_end_or_past_life
  maintenance_failure_risk
  // coverage_gap_resolution
  coverage_gap
  coverage_lapse_detected
  // recall_safety_resolution
  recall_detected
  // weather_risk_resolution (S6-38: expanded from freeze_risk only)
  freeze_risk
  flood_risk
  hurricane_risk
  wind_risk
  heat_risk
  wildfire_risk
  // inspection_followup_resolution
  inspection_followup_needed
  // financial_exposure_resolution
  financial_exposure
  // financial_inaction_resolution
  cost_of_inaction_risk
  // compliance_resolution (S6-37)
  permit_required
  hoa_violation_detected
  safety_inspection_due
  // energy_efficiency_resolution (S6-37)
  energy_inefficiency_detected
  high_utility_cost
  // DEFAULT_TEMPLATE catch-all
  generic_actionable_signal
}

enum GuidanceDecisionStage {
  AWARENESS
  DIAGNOSIS
  DECISION
  EXECUTION
  VALIDATION
  TRACKING
}

// P4-6: Enum for GuidanceJourneyStep.stepType (previously untyped String?).
// Values intentionally mirror GuidanceDecisionStage — stepType describes
// the nature of the action taken at this step, while decisionStage describes
// where the journey is in its overall lifecycle.
enum GuidanceStepType {
  AWARENESS
  DIAGNOSIS
  DECISION
  VALIDATION
  EXECUTION
  TRACKING
}

enum GuidanceExecutionReadiness {
  NOT_READY
  NEEDS_CONTEXT
  READY
  TRACKING_ONLY
  UNKNOWN
}

enum GuidanceSignalStatus {
  ACTIVE
  RESOLVED
  SUPPRESSED
  ARCHIVED
}

enum GuidanceJourneyStatus {
  NOT_STARTED // IMP-GE-1: User-initiated journey created before the first step is taken
  ACTIVE      // Journey is in progress
  COMPLETED   // All required steps are complete
  ABORTED     // System-cancelled; internal only — do not surface as user-facing copy
  ARCHIVED    // System-archived; internal only — do not surface as user-facing copy
  DISMISSED   // IMP-GE-1: User explicitly marked "not relevant" via override control
}

enum GuidanceStepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
  BLOCKED
}

enum GuidanceSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
  UNKNOWN
}

// P4-17: Identifies who or what triggered a guidance event.
// USER = homeowner or admin acting via UI; SYSTEM = engine-internal recompute;
// WORKER = background BullMQ job.
enum GuidanceActorType {
  USER
  SYSTEM
  WORKER
}

enum GuidanceJourneyEventType {
  JOURNEY_CREATED
  JOURNEY_STATUS_CHANGED
  JOURNEY_READINESS_CHANGED
  STEP_STATUS_CHANGED
  STEP_STARTED
  STEP_COMPLETED
  STEP_SKIPPED
  STEP_BLOCKED
  STEP_UNBLOCKED
  CONTEXT_UPDATED
  DERIVED_DATA_UPDATED
  JOURNEY_DISMISSED     // IMP-GE-1: User clicked "Not relevant"; actorType must be USER
  JOURNEY_SCOPE_CHANGED // IMP-GE-1: User clicked "Change asset"; links old journey to replacement
  JOURNEY_ISSUE_CHANGED // IMP-GE-1: User clicked "Different issue"; issueType updated on journey
}

enum GuidanceEvidenceType {
  TOOL_RESULT
  BOOKING_RECORD
  POLICY_UPDATE
  QUOTE_CAPTURE
  NEGOTIATION_ARTIFACT
  DOCUMENT_PROOF
  COMMUNICATION_LOG
  USER_CONFIRMATION
  SYSTEM_DERIVATION
  OTHER
}

enum GuidanceEvidenceSourceType {
  INTERNAL_TOOL
  INTEGRATION
  EVENT_PIPELINE
  USER_INPUT
  SYSTEM_WORKER
}

enum GuidanceEvidenceStatus {
  CAPTURED
  VERIFIED
  REJECTED
  SUPERSEDED
}

// Normalized actionable signal; can be produced by any CtC tool, worker, or resolver.
model GuidanceSignal {
  id String @id @default(uuid())

  propertyId      String
  homeAssetId     String?
  inventoryItemId String?

  signalKey String? // Optional external signal id (for imports/backfills). No unique constraint — not guaranteed stable across sources.

  // P4-1: Typed to GuidanceSignalIntentFamily enum. Manual ALTER TABLE ... USING cast
  // was applied to existing data before this schema change was committed.
  signalIntentFamily GuidanceSignalIntentFamily
  issueDomain        GuidanceIssueDomain
  decisionStage      GuidanceDecisionStage
  executionReadiness GuidanceExecutionReadiness @default(UNKNOWN)
  status             GuidanceSignalStatus       @default(ACTIVE)

  severity GuidanceSeverity?

  // P4-4: Application must clamp to 0–100 before write. No native Prisma CHECK
  // constraint — enforce via DB migration: CHECK (severity_score >= 0 AND severity_score <= 100)
  severityScore Int?

  // P4-3: Application must clamp to 0.0000–1.0000 before write. No native Prisma CHECK
  // constraint — enforce via DB migration: CHECK (confidence_score >= 0 AND confidence_score <= 1)
  confidenceScore Decimal? @db.Decimal(5, 4)

  sourceType         SignalSourceType?
  sourceFeatureKey   String?
  sourceToolKey      String?
  sourceEntityType   String?
  sourceEntityId     String?
  sourceRunId        String?
  sourceProvenanceId String?

  // P4-2: Promoted from @@index to @@unique. Enforces deduplication at DB level.
  // Concurrent ingests of the same event will conflict and be handled as idempotent upserts.
  // NULL dedupeKey rows are exempt — PostgreSQL treats each NULL as distinct in a unique index.
  dedupeKey         String?
  duplicateGroupKey String?

  actionWeaknessFlags   String[] @default([])
  contextPrerequisites  String[] @default([])
  missingContextKeys    String[] @default([])
  canonicalFirstStepKey String?
  recommendedToolKey    String?
  recommendedFlowKey    String?

  payloadJson  Json?
  metadataJson Json?

  firstObservedAt DateTime  @default(now())
  lastObservedAt  DateTime  @default(now())
  resolvedAt      DateTime?
  archivedAt      DateTime?

  // P4-16: Time-bounded signals (e.g. freeze_risk) should set expiresAt. A background
  // worker checks this field and transitions expired ACTIVE signals to ARCHIVED.
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property         Property               @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  homeAsset        HomeAsset?             @relation(fields: [homeAssetId], references: [id], onDelete: SetNull)
  inventoryItem    InventoryItem?         @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  sourceProvenance SignalProvenance?      @relation(fields: [sourceProvenanceId], references: [id], onDelete: SetNull)
  journeys         GuidanceJourney[]
  events           GuidanceJourneyEvent[]
  evidences        GuidanceStepEvidence[]

  @@unique([propertyId, dedupeKey]) // P4-2: replaces former @@index([propertyId, dedupeKey])
  @@index([propertyId, status, lastObservedAt(sort: Desc)])
  @@index([propertyId, executionReadiness])
  @@index([propertyId, issueDomain])
  @@index([propertyId, signalIntentFamily])
  @@index([propertyId, signalIntentFamily, status, lastObservedAt(sort: Desc)])
  @@index([duplicateGroupKey])
  @@index([homeAssetId])
  @@index([inventoryItemId])
  @@index([propertyId, inventoryItemId, status, lastObservedAt(sort: Desc)])
  @@index([propertyId, homeAssetId, status, lastObservedAt(sort: Desc)])
  @@index([sourceEntityType, sourceEntityId])
  @@index([sourceToolKey, sourceFeatureKey])
  @@index([sourceProvenanceId])
  @@index([expiresAt]) // P4-16: supports worker query for expired signal archival
  @@map("guidance_signals")
}

// Deterministic action plan for one primary signal or a merged signal group.
model GuidanceJourney {
  id String @id @default(uuid())

  propertyId      String
  homeAssetId     String?
  inventoryItemId String?
  primarySignalId String?

  journeyKey String?

  // P4-5: Should be NOT NULL — a journey without journeyTypeKey cannot be matched
  // back to its template for step resolution or skip policy lookup.
  // Kept nullable for now; set NOT NULL after data migration clears legacy null rows.
  journeyTypeKey String?

  issueDomain        GuidanceIssueDomain
  decisionStage      GuidanceDecisionStage      @default(AWARENESS)
  executionReadiness GuidanceExecutionReadiness @default(UNKNOWN)
  status             GuidanceJourneyStatus      @default(ACTIVE)

  mergedSignalGroupKey String?
  currentStepOrder     Int?
  currentStepKey       String?

  isLowContext       Boolean  @default(false)
  missingContextKeys String[] @default([])

  contextSnapshotJson Json?
  derivedSnapshotJson Json?

  // P4-11: Tracks which template version created the steps on this journey.
  // Format: "<journeyTypeKey>@<semver>", e.g. "asset_lifecycle_resolution@1.0.0".
  // When the template version in code is newer than this value, the journey engine
  // can flag the journey for step re-hydration or surface a staleness warning.
  templateVersion String?

  // P4-12: Optimistic locking counter. Incremented on every state write.
  // Update queries should use WHERE version = :expected and retry on mismatch
  // to prevent lost updates from concurrent recomputeJourneyState() calls.
  version Int @default(0)

  // ---------------------------------------------------------------------------
  // IMP-GE-1: User-first scope model fields
  // ---------------------------------------------------------------------------

  // Top-level scope category. Set at journey creation.
  // Nullable during migration window; backfill sets ITEM for all existing journeys.
  // Once backfill is confirmed clean this column should be made NOT NULL.
  scopeCategory GuidanceScopeCategory?

  // Denormalized scope identifier for API simplicity.
  // ITEM journeys: inventoryItemId if available, otherwise homeAssetId.
  // SERVICE journeys: serviceKey value.
  // Nullable during migration window; backfill derives from COALESCE(inventory_item_id, home_asset_id).
  scopeId String?

  // User-selected issue label. Free-text or from the suggested issue type list.
  // Null for system-generated (signal-driven) journeys.
  // Populated for user-initiated journeys only.
  issueType String?

  // Service key for SERVICE-scoped journeys not tied to an inventory item or home asset.
  // Examples: "warranty_purchase", "insurance_purchase", "general_inspection", "cleaning".
  // Null for all ITEM-scoped journeys.
  serviceKey String?

  // Populated when status is set to DISMISSED.
  dismissedReason String?
  dismissedAt     DateTime?

  // Distinguishes user-initiated journeys (via "start journey" flow) from
  // system-generated journeys (signal ingestion). Defaults false to preserve
  // existing behaviour for all signal-driven journeys.
  isUserInitiated Boolean @default(false)

  // ---------------------------------------------------------------------------

  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  abortedAt        DateTime?
  archivedAt       DateTime?
  lastTransitionAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property      Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  homeAsset     HomeAsset?      @relation(fields: [homeAssetId], references: [id], onDelete: SetNull)
  inventoryItem InventoryItem?  @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  primarySignal GuidanceSignal? @relation(fields: [primarySignalId], references: [id], onDelete: SetNull)

  steps      GuidanceJourneyStep[]
  events     GuidanceJourneyEvent[]
  evidences  GuidanceStepEvidence[]
  homeEvents HomeEvent[]           // FRD-FR-11/FR-03: retrospective lookback + verified resolution events

  @@index([propertyId, status, updatedAt(sort: Desc)])
  @@index([propertyId, executionReadiness, status])
  @@index([propertyId, issueDomain, status])
  @@index([propertyId, journeyTypeKey, status])          // P4-13: supports ensureJourneyForSignal() lookup
  @@index([propertyId, currentStepOrder])
  @@index([propertyId, inventoryItemId, status, updatedAt(sort: Desc)])
  @@index([propertyId, homeAssetId, status, updatedAt(sort: Desc)])
  @@index([primarySignalId])
  @@index([mergedSignalGroupKey])
  @@index([homeAssetId])
  @@index([inventoryItemId])
  // IMP-GE-1: indexes for new user-first scope fields
  @@index([propertyId, scopeCategory, status, updatedAt(sort: Desc)])
  @@index([propertyId, scopeId, status])
  @@index([propertyId, scopeCategory, scopeId, status])
  @@index([propertyId, isUserInitiated, status])
  @@index([serviceKey])
  @@map("guidance_journeys")
}

model GuidanceJourneyStep {
  id String @id @default(uuid())

  journeyId   String
  stepOrder   Int
  stepKey     String

  // P4-6: Typed to GuidanceStepType enum. Previously untyped String? — any value
  // was accepted silently. Note: stepType mirrors decisionStage values and is not
  // read by any business logic today; tracked for future sub-flow routing use.
  stepType GuidanceStepType?

  label       String
  description String?

  decisionStage      GuidanceDecisionStage?
  executionReadiness GuidanceExecutionReadiness @default(UNKNOWN)
  status             GuidanceStepStatus         @default(PENDING)
  isRequired         Boolean                    @default(true)

  toolKey   String?
  // S6-39: flowKey removed — was stored for future sub-flow routing but never consumed.
  routePath String? // Copied from template at journey creation. May become stale if template changes (see templateVersion on GuidanceJourney).

  requiredContextKeys String[] @default([])
  missingContextKeys  String[] @default([])

  // TODO: blockedReasonCode and skippedReasonCode are candidates for enums
  // once the full set of reason codes is stabilised across all journey types.
  blockedReasonCode String?
  blockedReason     String?
  skippedReasonCode String?
  skippedReason     String?

  inputContextJson Json?
  producedDataJson Json?

  startedAt   DateTime?
  completedAt DateTime?
  skippedAt   DateTime?
  blockedAt   DateTime?
  unblockedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  journey GuidanceJourney        @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  events  GuidanceJourneyEvent[]
  evidences GuidanceStepEvidence[]

  @@unique([journeyId, stepOrder])
  @@unique([journeyId, stepKey])
  @@index([journeyId, status, stepOrder])
  @@index([journeyId, isRequired, status, stepOrder])
  @@index([journeyId, decisionStage, status])
  @@index([journeyId, executionReadiness])
  @@index([journeyId, toolKey]) // P4-14: supports GuidanceBookingGuardService step filtering by toolKey
  @@index([toolKey, status])
  @@index([toolKey])
  @@map("guidance_journey_steps")
}

// Guidance-specific transition ledger; existing event tables are feature-specific.
// Append-only — no updatedAt. Rows are never mutated after insert.
model GuidanceJourneyEvent {
  id String @id @default(uuid())

  propertyId String
  journeyId  String
  stepId     String?
  signalId   String?

  eventType GuidanceJourneyEventType

  // Journey status transition fields (populated for JOURNEY_STATUS_CHANGED)
  fromJourneyStatus GuidanceJourneyStatus?
  toJourneyStatus   GuidanceJourneyStatus?

  // P4-7: Journey readiness transition fields (populated for JOURNEY_READINESS_CHANGED).
  // Previously missing — the event type existed but before/after values were never recorded.
  fromJourneyReadiness GuidanceExecutionReadiness?
  toJourneyReadiness   GuidanceExecutionReadiness?

  // Step status transition fields (populated for STEP_* events)
  fromStepStatus GuidanceStepStatus?
  toStepStatus   GuidanceStepStatus?

  // P4-17: Identifies the actor that triggered this event.
  // USER = homeowner/admin via UI; SYSTEM = engine-internal recompute; WORKER = BullMQ job.
  // Defaults to SYSTEM so existing engine-generated events are correctly typed.
  actorType   GuidanceActorType? @default(SYSTEM)
  actorUserId String? // Populated only when actorType = USER

  reasonCode    String?
  reasonMessage String?

  // P4-8: List of context/derived-data keys that changed.
  // Populated for CONTEXT_UPDATED and DERIVED_DATA_UPDATED events.
  // Enables audit queries like "which context keys changed and when?"
  changedKeys String[] @default([])

  payloadJson Json?

  createdAt DateTime @default(now())

  property Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  journey  GuidanceJourney      @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  step     GuidanceJourneyStep? @relation(fields: [stepId], references: [id], onDelete: SetNull)
  signal   GuidanceSignal?      @relation(fields: [signalId], references: [id], onDelete: SetNull)

  @@index([propertyId, createdAt(sort: Desc)])
  @@index([propertyId, journeyId, createdAt(sort: Desc)])
  @@index([journeyId, createdAt(sort: Desc)])
  @@index([journeyId, eventType, createdAt(sort: Desc)]) // P4-15: supports per-journey event type queries
  @@index([stepId, createdAt(sort: Desc)])
  @@index([signalId, createdAt(sort: Desc)])
  @@index([eventType, createdAt(sort: Desc)])
  @@map("guidance_journey_events")
}

model GuidanceStepEvidence {
  id String @id @default(uuid())

  propertyId String
  journeyId  String
  stepId     String
  signalId   String?

  homeAssetId     String?
  inventoryItemId String?

  evidenceType GuidanceEvidenceType
  sourceType   GuidanceEvidenceSourceType @default(INTERNAL_TOOL)
  status       GuidanceEvidenceStatus     @default(CAPTURED)

  sourceToolKey    String?
  sourceFeatureKey String?
  evidenceRefType  String?
  evidenceRefId    String?
  proofType        String?
  proofId          String?
  confidenceScore  Decimal? @db.Decimal(5, 4)

  observedAt   DateTime @default(now())
  verifiedAt   DateTime?
  invalidatedAt DateTime?

  supersededById String?
  createdByUserId String?

  payloadJson  Json?
  metadataJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property      Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  journey       GuidanceJourney      @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  step          GuidanceJourneyStep  @relation(fields: [stepId], references: [id], onDelete: Cascade)
  signal        GuidanceSignal?      @relation(fields: [signalId], references: [id], onDelete: SetNull)
  homeAsset     HomeAsset?           @relation(fields: [homeAssetId], references: [id], onDelete: SetNull)
  inventoryItem InventoryItem?       @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  supersededBy  GuidanceStepEvidence? @relation("GuidanceStepEvidenceSupersession", fields: [supersededById], references: [id], onDelete: SetNull)
  supersedes    GuidanceStepEvidence[] @relation("GuidanceStepEvidenceSupersession")

  @@index([propertyId, observedAt(sort: Desc)])
  @@index([journeyId, stepId, observedAt(sort: Desc)])
  @@index([journeyId, stepId, status, observedAt(sort: Desc)])
  @@index([signalId, observedAt(sort: Desc)])
  @@index([inventoryItemId, observedAt(sort: Desc)])
  @@index([homeAssetId, observedAt(sort: Desc)])
  @@index([evidenceRefType, evidenceRefId])
  @@index([sourceToolKey, sourceFeatureKey, observedAt(sort: Desc)])
  @@index([evidenceType, status, observedAt(sort: Desc)])
  @@index([proofId])
  @@map("guidance_step_evidences")
}

