  @@unique([propertyId, sourceName, factKey, effectiveAt])
  @@index([propertyId, sourceName, effectiveAt(sort: Desc)])
  @@index([runId])
  @@map("home_score_data_source_facts")
}

model HomeScoreIntegrityCheckRun {
  id              String                 @id @default(uuid())
