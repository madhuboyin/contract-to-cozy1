  inventoryItemId String? // Link to the specific asset (e.g., HVAC)

  taskName      String // e.g., "Replace AC Capacitor"
  predictedDate DateTime
  priority      Int      @default(1) // 1 (Low) to 5 (Critical)

  // Intelligence Metadata
  reasoning       String? // e.g., "Based on 15-year average lifespan for [Model]"
