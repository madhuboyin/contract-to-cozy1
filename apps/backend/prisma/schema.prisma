// ============================================================================
// NARRATIVE
// ============================================================================

enum NarrativeRunStatus {
  ACTIVE
  DISMISSED
  COMPLETED
  EXPIRED
}

model PropertyInsightSnapshot {
  id         String @id @default(uuid())
  propertyId String
  userId     String

  // versioning so you can evolve logic safely
  schemaVersion String @default("v1")

  // derived signals used by narrative (ageBand, sizeBand, regionKey, etc.)
  snapshotJson Json

  // 0..100 (optional but recommended)
  confidenceScore Int @default(0)

  computedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  // relations
  narrativeRuns PropertyNarrativeRun[]

  @@index([propertyId, computedAt])
  @@index([userId, computedAt])
  @@index([schemaVersion])
  @@map("property_insight_snapshots")
}

model PropertyNarrativeRun {
  id         String @id @default(uuid())
  propertyId String
  userId     String

  // which narrative engine version generated this run
  version String @default("v1")

  status NarrativeRunStatus @default(ACTIVE)

  // snapshot used to generate this (optional but preferred)
  snapshotId String?

  // rule selections (block IDs, variant keys, ordering, experiment keys)
  planJson Json

  // fully rendered blocks (ready for UI)
  payloadJson Json

  // lifecycle
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  dismissedAt DateTime?
  expiresAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property Property                 @relation(fields: [propertyId], references: [id])
  user     User                     @relation(fields: [userId], references: [id])
  snapshot PropertyInsightSnapshot? @relation(fields: [snapshotId], references: [id])

  @@index([propertyId, status, createdAt])
  @@index([userId, status, createdAt])
  @@index([snapshotId])
  @@index([version])
  @@map("property_narrative_runs")
}

