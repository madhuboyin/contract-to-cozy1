  MODEL_OUTPUT
  SENSOR_READING
  USER_REPORT
  SYSTEM_RULE
  INSURANCE_POLICY_EXPIRY
  WEATHER_FORECAST_MIN_TEMP
  WEATHER_FORECAST_HEAVY_RAIN
}

