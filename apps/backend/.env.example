NODE_ENV=production
# Comma-separated list of frontend origins the backend will accept CORS requests from.
# Required in production. In development defaults to http://localhost:3000 if unset.
ALLOWED_ORIGINS=https://contracttocozy.com,https://www.contracttocozy.com
PORT=8080
DATABASE_URL=postgresql://postgres:password@postgres:5432/contracttocozy
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here
JWT_SECRET=your-jwt-secret-here
# Google Gemini API Key (server-side only — never prefix with NEXT_PUBLIC_)
GEMINI_API_KEY=your-gemini-api-key-here
# REQUIRED in production — protects the /metrics endpoint from public access.
# Generate with: openssl rand -hex 32
# Set this same value in your Prometheus scrape config as a Bearer token.
METRICS_BEARER_TOKEN=
# REQUIRED in production — signs the double-submit CSRF cookie.
# Generate with: openssl rand -hex 32
CSRF_SECRET=
# REQUIRED in production — 32-byte AES-256 key used to encrypt TOTP secrets at rest.
# Generate with: openssl rand -hex 32
MFA_ENCRYPTION_KEY=
# REQUIRED in production — signs short-lived MFA challenge JWTs (5 min TTL).
# Generate with: openssl rand -hex 32
JWT_MFA_SECRET=
NEXT_PUBLIC_FEATURE_BUDGET_TRACKER=true
NEXT_PUBLIC_FEATURE_VALUE_ESTIMATOR=true
NEXT_PUBLIC_FEATURE_FEEDBACK_WIDGET=true
NEXT_PUBLIC_FEATURE_MILESTONE_CELEBRATIONS=true
